#!/usr/bin/env bash
# test-iso — build the installer ISO with SSH keys and boot it in QEMU
#
# Usage:
#   ./bin/test-iso                          # auto-detect ~/.ssh/id_*.pub
#   ./bin/test-iso --ssh-key ~/.ssh/id_ed25519.pub
#   ./bin/test-iso --ssh-key "ssh-ed25519 AAAA... user@host"
#   ./bin/test-iso --build-only             # build but don't start VM
#   ./bin/test-iso --no-build               # skip build, boot existing ISO
#   ./bin/test-iso --dev                    # build from a dirty tree and use a repo-local test SSH key
#   ./bin/test-iso --update-keystone-input  # refresh keystone flake input before build
#
# SSH access once the VM boots:
#   ssh -p 2222 -o StrictHostKeyChecking=no keystone@localhost

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_DIR="$(dirname "$SCRIPT_DIR")"
ISO_RESULT="$PROJECT_DIR/.test-iso"
VM_DISK_PATH="$PROJECT_DIR/.test-iso-disk.raw"
SSH_PORT=12222
# Full installs regularly realize large target closures, so use the same
# baseline we needed in manual verification instead of the old 4 GiB / 2 vCPU
# defaults that pushed `nixos-install` into OOM territory.
QEMU_MEM=8192
QEMU_CPUS=4
SSH_WAIT_TIMEOUT=240
VM_DISK_SIZE=64G
DEV_SSH_KEY_PATH="$PROJECT_DIR/.test-iso-dev-key"
USE_DEV_SSH_KEY=false

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

log_info()  { echo -e "${BLUE}$*${NC}" >&2; }
log_ok()    { echo -e "${GREEN}$*${NC}" >&2; }
log_warn()  { echo -e "${YELLOW}$*${NC}" >&2; }
log_error() { echo -e "${RED}$*${NC}" >&2; }

PROJECT_SNAPSHOT_DIR=""

cleanup_project_snapshot() {
    if [[ -n "$PROJECT_SNAPSHOT_DIR" && -d "$PROJECT_SNAPSHOT_DIR" ]]; then
        rm -rf "$PROJECT_SNAPSHOT_DIR"
    fi
}

trap cleanup_project_snapshot EXIT

check_iso_artifact() {
    local iso_path="$1"
    local check_output

    log_info "Verifying installer ISO artifact..."
    if ! check_output="$(
        nix shell nixpkgs#xorriso nixpkgs#squashfsTools --command bash -s -- "$iso_path" <<'EOF' 2>&1
set -euo pipefail

iso_path="$1"
tmp="$(mktemp -d)"
trap 'rm -rf "$tmp"' EXIT

# Prove we built the Keystone installer artifact, not just any bootable ISO.
# xorriso has changed the exact casing and quoting of this field across
# versions, so accept the known variants instead of pinning to one rendering.
xorriso -indev "$iso_path" -pvd_info > "$tmp/pvd.txt" 2>&1
grep -Eq "Volume [Ii]d[[:space:]]*:[[:space:]]*'?KEYSTONE'?" "$tmp/pvd.txt" >/dev/null

# version.txt is a cheap sanity check that the ISO root filesystem layout is intact.
xorriso -osirrox on -indev "$iso_path" -extract /version.txt "$tmp/version.txt" >/dev/null 2>&1
grep -Eq '^[0-9]{2}\.[0-9]{2}\.' "$tmp/version.txt"

xorriso -osirrox on -indev "$iso_path" -extract /nix-store.squashfs "$tmp/nix-store.squashfs" >/dev/null 2>&1
# Keep the known-good ICU read gate that caught the earlier corrupt squashfs issue.
unsquashfs -cat "$tmp/nix-store.squashfs" 4424mzk2pyia5v1j33zjgrjaivrdy03y-icu4c-76.1/lib/libicudata.so.76 >/dev/null
unsquashfs -ll "$tmp/nix-store.squashfs" > "$tmp/nix-store.list"

# Make sure the live installer closure still carries the commands the ISO boot flow needs.
for tool in ks disko nixos-install; do
    grep -Eq "/bin/${tool}$" "$tmp/nix-store.list"
done
EOF
    )"; then
        log_error "Installer ISO artifact gate failed."
        printf '%s\n' "$check_output" >&2
        exit 1
    fi
    log_ok "Installer ISO artifact checks passed."
}

show_help() {
    cat >&2 << EOF
test-iso — build the installer ISO with SSH keys and boot it in QEMU

Usage:
  $(basename "$0") [OPTIONS]

Options:
  -k, --ssh-key INPUT   SSH public key as a file path or inline key string.
                        May be repeated for multiple keys.
                        Default: all ~/.ssh/id_*.pub files.
  --build-only          Build the ISO but do not start the VM.
  --no-build            Skip the build step and boot an existing ISO.
  --dev                 Allow building from a dirty working tree snapshot.
                        In --dev mode, the script prefers a repo-local
                        gitignored SSH key at $DEV_SSH_KEY_PATH and generates
                        it automatically if missing. Without this flag, the
                        repo must be clean.
  --update-keystone-input
                        Refresh flake input 'keystone' before building.
                        For path-locked keystone inputs, this refreshes the
                        lock to the current local path snapshot.
  --headless            No GUI window — poll for SSH in the background.
  --e2e                 Requires --headless --dev. After SSH is up, drive the
                        installer TUI with deterministic keystrokes, poll for
                        install checkpoints, and report pass/fail.
  --ssh-timeout SEC     Max wait time for SSH in headless mode (default: $SSH_WAIT_TIMEOUT).
  --disk-size SIZE      Size of the attached install disk image (default: $VM_DISK_SIZE).
  --disk-path PATH      Path to the attached install disk image
                        (default: $VM_DISK_PATH).
  -m, --memory MB       QEMU RAM in MB (default: $QEMU_MEM).
  -c, --cpus N          QEMU vCPU count (default: $QEMU_CPUS).
  -p, --port PORT       Host SSH port to forward (default: $SSH_PORT).
  -h, --help            Show this help.

By default the QEMU window opens (GUI mode) with serial output on the
terminal. Use --headless to run without a window (SSH-only).

Examples:
  ./bin/test-iso                           # GUI + serial
  ./bin/test-iso --dev                     # build from local changes + use repo-local test SSH key
  ./bin/test-iso --headless                # no window, polls SSH
  ./bin/test-iso --disk-size 100G          # attach a larger install disk
  ./bin/test-iso --update-keystone-input   # refresh keystone input then build
  ./bin/test-iso --ssh-key ~/.ssh/id_ed25519.pub
  ./bin/test-iso --build-only
EOF
}

# ── argument parsing ──────────────────────────────────────────────────────────

SSH_KEY_INPUTS=()
BUILD=true
BOOT=true
HEADLESS=false
E2E_MODE=false
UPDATE_KEYSTONE_INPUT=false
DEV_MODE=false

# Admin identity — read from flake outputs (mkSystemFlake exposes these).
ADMIN_USERNAME=""
ADMIN_NAME=""
ADMIN_EMAIL=""
KEYSTONE_LOCKED_PATH=""

while [[ $# -gt 0 ]]; do
    case $1 in
        -k|--ssh-key)
            SSH_KEY_INPUTS+=("$2")
            shift 2
            ;;
        --build-only)
            BOOT=false
            shift
            ;;
        --no-build)
            BUILD=false
            shift
            ;;
        --update-keystone-input)
            UPDATE_KEYSTONE_INPUT=true
            shift
            ;;
        --dev)
            DEV_MODE=true
            shift
            ;;
        --headless)
            HEADLESS=true
            shift
            ;;
        --e2e)
            E2E_MODE=true
            shift
            ;;
        --ssh-timeout)
            SSH_WAIT_TIMEOUT="$2"
            shift 2
            ;;
        --disk-size)
            VM_DISK_SIZE="$2"
            shift 2
            ;;
        --disk-path)
            VM_DISK_PATH="$2"
            shift 2
            ;;
        -m|--memory)
            QEMU_MEM="$2"
            shift 2
            ;;
        -c|--cpus)
            QEMU_CPUS="$2"
            shift 2
            ;;
        -p|--port)
            SSH_PORT="$2"
            shift 2
            ;;
        -h|--help)
            show_help
            exit 0
            ;;
        *)
            log_error "Unknown option: $1"
            show_help
            exit 1
            ;;
    esac
done

# ── e2e mode gate ────────────────────────────────────────────────────────────

if [[ "$E2E_MODE" == "true" ]]; then
    if [[ "$HEADLESS" != "true" || "$DEV_MODE" != "true" ]]; then
        log_error "--e2e requires both --headless and --dev"
        exit 1
    fi
fi

E2E_INSTALL_TIMEOUT=900   # 15 minutes for nixos-install to complete
E2E_CHECKPOINT_POLL=30    # seconds between checkpoint polls

# SSH command fragments reused by the e2e driver.
ssh_cmd() {
    ssh "${SSH_IDENTITY_ARGS[@]}" \
        -p "$SSH_PORT" \
        -o StrictHostKeyChecking=no \
        -o UserKnownHostsFile=/dev/null \
        -o ConnectTimeout=5 \
        "${ADMIN_USERNAME}@localhost" "$@"
}

# Drive the ks installer TUI with deterministic keystrokes via expect.
#
# Expect keeps the SSH PTY open for the entire install so ks has a live
# terminal.  The checkpoint poller runs from a separate SSH session.
run_e2e_installer() {
    local expect_bin
    expect_bin="$(command -v expect 2>/dev/null || true)"
    if [[ -z "$expect_bin" ]]; then
        log_error "--e2e requires 'expect' (tcl-expect). Install it or add it to your devshell."
        exit 1
    fi

    log_info "E2E: driving installer TUI with deterministic keystrokes"

    local ssh_args=(-tt)
    ssh_args+=("${SSH_IDENTITY_ARGS[@]}")
    ssh_args+=(-p "$SSH_PORT")
    ssh_args+=(-o StrictHostKeyChecking=no)
    ssh_args+=(-o UserKnownHostsFile=/dev/null)
    ssh_args+=(-o ServerAliveInterval=30)

    # Run expect in background — it keeps the PTY alive while ks runs.
    # The checkpoint poller takes over in the foreground.
    "$expect_bin" - "${ssh_args[@]}" "${ADMIN_USERNAME}@localhost" << 'EXPECT_SCRIPT' &
set timeout 120
set ssh_args [lrange $argv 0 end]

eval spawn env TERM=xterm-256color ssh $ssh_args ks

# Screen 1: host selection — wait for the TUI to render.
# The first item (laptop) is focused by default.  Just press Enter.
expect {
    -re {Host|host|Select} { }
    timeout { send_user "\n>>> TIMEOUT waiting for host screen\n"; exit 1 }
}
sleep 1
send "\r"

# Screen 2: disk selection
expect {
    -re {Disk|disk|Select} { }
    timeout { send_user "\n>>> TIMEOUT waiting for disk screen\n"; exit 1 }
}
sleep 1
send "\r"

# Screen 3: confirmation
expect {
    -re {Confirm|confirm|Begin|Install|install} { }
    timeout { send_user "\n>>> TIMEOUT waiting for confirm screen\n"; exit 1 }
}
sleep 1
send "\r"

send_user "\n>>> Keys sent, keeping PTY alive for install...\n"

# Keep the SSH session open while ks runs (up to 30 minutes).
set timeout 1800
expect {
    eof { send_user "\n>>> ks session ended\n" }
    timeout { send_user "\n>>> Install timeout\n"; exit 1 }
}
EXPECT_SCRIPT
    E2E_EXPECT_PID=$!

    # Brief wait for expect to send all keys before polling starts.
    sleep 15

    log_ok "E2E: installer TUI driven (expect PID $E2E_EXPECT_PID)"
}

# Poll install checkpoints from the live ISO until they all pass or timeout.
run_e2e_checkpoints() {
    local repo_name
    repo_name="$(basename "$PROJECT_DIR")"

    log_info "E2E: polling install checkpoints (timeout: ${E2E_INSTALL_TIMEOUT}s)"

    local start_time
    start_time="$(date +%s)"

    while true; do
        local now elapsed
        now="$(date +%s)"
        elapsed=$(( now - start_time ))
        if (( elapsed >= E2E_INSTALL_TIMEOUT )); then
            log_error "E2E: install checkpoint timeout after ${E2E_INSTALL_TIMEOUT}s"
            return 1
        fi

        if ssh_cmd "sudo -n test -f /mnt/nix/var/nix/profiles/system" 2>/dev/null; then
            break
        fi
        log_info "E2E: waiting for system profile... (${elapsed}s elapsed)"
        sleep "$E2E_CHECKPOINT_POLL"
    done

    log_ok "E2E: system profile exists"

    # Verify all checkpoints
    local failed=0

    if ssh_cmd "sudo -n test -f /mnt/etc/keystone/system-flake" 2>/dev/null; then
        log_ok "E2E: /etc/keystone/system-flake exists"
    else
        log_error "E2E: /etc/keystone/system-flake MISSING"
        failed=1
    fi

    if ssh_cmd "sudo -n test -f /mnt/home/${ADMIN_USERNAME}/.ssh/authorized_keys" 2>/dev/null; then
        log_ok "E2E: authorized_keys exists"
    else
        log_error "E2E: authorized_keys MISSING"
        failed=1
    fi

    local repo_marker="/mnt/home/${ADMIN_USERNAME}/.keystone/repos/${ADMIN_USERNAME}/${repo_name}/.first-boot-pending"
    if ssh_cmd "sudo -n test -f '${repo_marker}'" 2>/dev/null; then
        log_ok "E2E: first-boot-pending marker exists"
    else
        log_error "E2E: first-boot-pending marker MISSING"
        failed=1
    fi

    if (( failed )); then
        log_error "E2E: FAIL — some checkpoints missing"
        return 1
    fi

    log_ok "E2E: PASS — all install checkpoints verified"
    return 0
}

# ── read admin identity from flake ───────────────────────────────────────────

ADMIN_USERNAME="$(nix eval --raw "${PROJECT_DIR}#adminUsername" 2>/dev/null)"
ADMIN_NAME="$(nix eval --raw "${PROJECT_DIR}#adminName" 2>/dev/null)"
ADMIN_EMAIL="$(nix eval --raw "${PROJECT_DIR}#adminEmail" 2>/dev/null)"

if [[ -z "$ADMIN_USERNAME" ]]; then
    log_error "Could not read adminUsername from flake. Ensure the flake uses mkSystemFlake and has admin.username set."
    exit 1
fi

if [[ -f "$PROJECT_DIR/flake.lock" ]]; then
    KEYSTONE_LOCKED_PATH="$(jq -r '.nodes.keystone.locked.path // empty' "$PROJECT_DIR/flake.lock" 2>/dev/null || true)"
fi

refresh_keystone_input() {
    local node_json locked_type locked_path

    node_json="$(nix flake metadata --json "$PROJECT_DIR" 2>/dev/null | jq -c '.locks.nodes.keystone // empty')"
    if [[ -z "$node_json" ]]; then
        log_warn "Could not inspect flake lock for 'keystone'; running targeted update."
        nix flake update keystone
        return
    fi

    locked_type="$(jq -r '.locked.type // empty' <<< "$node_json")"
    if [[ "$locked_type" == "path" ]]; then
        locked_path="$(jq -r '.locked.path // empty' <<< "$node_json")"
        if [[ -n "$locked_path" ]]; then
            log_info "Refreshing path-locked keystone input: $locked_path"
            nix flake lock --override-input keystone "path:${locked_path}"
            return
        fi

        log_warn "Keystone input is path-locked but missing locked.path; running targeted update."
        nix flake update keystone
        return
    fi

    log_info "Updating flake input 'keystone'."
    nix flake update keystone
}

assert_clean_repo() {
    if [[ -n "$(git -C "$PROJECT_DIR" status --porcelain --untracked-files=normal)" ]]; then
        log_error "Refusing to build installer ISO from a dirty repo."
        log_error "Commit or stash changes first, or rebuild with --dev."
        exit 1
    fi
}

create_project_snapshot() {
    local snapshot_dir="$1"

    mkdir -p "$snapshot_dir"

    # Do not evaluate the flake from the raw working tree path.
    #
    # Nix will eagerly traverse that path before the installer snapshot logic
    # runs, which pulls local VM artifacts like .test-iso-disk.raw into the
    # build input. Build from a git-filtered temp snapshot instead so flake
    # evaluation and repo embedding see the same clean file set.
    if [[ "$DEV_MODE" == "true" ]]; then
        git -C "$PROJECT_DIR" ls-files -z --cached --modified --others --exclude-standard \
            | (cd "$PROJECT_DIR" && tar --null -T - -cf -) \
            | tar -xf - -C "$snapshot_dir"
    else
        git -C "$PROJECT_DIR" archive --format=tar HEAD | tar -xf - -C "$snapshot_dir"
    fi
}

# ── collect SSH keys ──────────────────────────────────────────────────────────

collect_keys() {
    # Returns a newline-separated list of SSH public key strings.
    local input
    for input in "${SSH_KEY_INPUTS[@]}"; do
        if [[ "$input" =~ ^[/~.] ]]; then
            # Expand ~ manually so the path check works
            local expanded="${input/#\~/$HOME}"
            if [[ ! -f "$expanded" ]]; then
                log_error "SSH key file not found: $input"
                exit 1
            fi
            grep "^ssh-" "$expanded" || true
        else
            echo "$input"
        fi
    done
}

ensure_dev_ssh_key() {
    local key_path="$1"
    local pub_path="${key_path}.pub"

    if [[ -f "$key_path" && -f "$pub_path" ]]; then
        return 0
    fi

    if ! command -v ssh-keygen >/dev/null 2>&1; then
        return 1
    fi

    log_info "Generating dev-only SSH key: $key_path"
    rm -f "$key_path" "$pub_path"
    ssh-keygen -q -t ed25519 -N "" -C "keystone-test-iso@$(hostname)" -f "$key_path" >/dev/null
}

SSH_KEYS_LIST=""

if [[ ${#SSH_KEY_INPUTS[@]} -gt 0 ]]; then
    SSH_KEYS_LIST="$(collect_keys)"
else
    if [[ "$DEV_MODE" == "true" ]] && ensure_dev_ssh_key "$DEV_SSH_KEY_PATH"; then
        USE_DEV_SSH_KEY=true
        log_info "Using dev-only SSH key: ${DEV_SSH_KEY_PATH}.pub"
        SSH_KEYS_LIST="$(grep "^ssh-" "${DEV_SSH_KEY_PATH}.pub" || true)"
    else
        # Auto-detect from ~/.ssh/id_*.pub
        local_pub_keys=()
        for f in "$HOME/.ssh/id_"*.pub; do
            [[ -f "$f" ]] && local_pub_keys+=("$f")
        done
        if [[ ${#local_pub_keys[@]} -eq 0 ]]; then
            if [[ "$DEV_MODE" == "true" ]]; then
                log_warn "Could not use a dev-only SSH key at ${DEV_SSH_KEY_PATH}.pub"
            fi
            log_warn "No SSH public keys found in ~/.ssh/id_*.pub"
            log_warn "The ISO will have no SSH access unless you pass --ssh-key"
        else
            for f in "${local_pub_keys[@]}"; do
                log_info "Using SSH key: $f"
                SSH_KEYS_LIST+="$(grep "^ssh-" "$f" || true)"$'\n'
            done
        fi
    fi
fi

SSH_IDENTITY_ARGS=()
if [[ "$USE_DEV_SSH_KEY" == "true" && -f "$DEV_SSH_KEY_PATH" ]]; then
    SSH_IDENTITY_ARGS=(-i "$DEV_SSH_KEY_PATH")
fi

# Build a Nix list literal: [ "key1" "key2" ]
nix_keys_list="["
while IFS= read -r key; do
    [[ -z "$key" ]] && continue
    escaped="${key//\"/\\\"}"
    nix_keys_list+=" \"$escaped\""
done <<< "$SSH_KEYS_LIST"
nix_keys_list+=" ]"

# ── build ─────────────────────────────────────────────────────────────────────

if [[ "$BUILD" == "true" ]]; then
    if [[ "$UPDATE_KEYSTONE_INPUT" == "true" ]]; then
        refresh_keystone_input
    fi

    if [[ "$DEV_MODE" != "true" ]]; then
        assert_clean_repo
    else
        log_warn "Building installer ISO in --dev mode from the current working tree snapshot."
    fi

    PROJECT_SNAPSHOT_DIR="$(mktemp -d)"
    create_project_snapshot "$PROJECT_SNAPSHOT_DIR"

    # Inject SSH keys into the snapshot's admin.sshKeys so they are part of the
    # NixOS configuration that nixos-install builds.  This makes the keys
    # available on the installed system through the declarative authorized_keys
    # path rather than relying on file-based injection.
    if [[ -n "$SSH_KEYS_LIST" ]]; then
        # Handle both commented and uncommented forms of the sshKeys field.
        sed -i "s|# sshKeys = \\[\\];.*|sshKeys = $nix_keys_list;|" \
            "$PROJECT_SNAPSHOT_DIR/flake.nix"
        sed -i "s|sshKeys = \\[\\];.*|sshKeys = $nix_keys_list;|" \
            "$PROJECT_SNAPSHOT_DIR/flake.nix"
    fi

    log_info "Building installer ISO..."

    keystone_expr="self.inputs.keystone"
    if [[ -n "$KEYSTONE_LOCKED_PATH" && -e "$KEYSTONE_LOCKED_PATH" ]]; then
        # Path-locked local keystone inputs are iterative development surfaces.
        # Read the live worktree directly here so test builds pick up the latest
        # keystone changes even when flake.lock still points at an older store
        # snapshot of the same path.
        keystone_expr="builtins.getFlake (toString $(printf '%q' "$KEYSTONE_LOCKED_PATH"))"
    fi

    # Build via keystone.lib.mkInstallerIsoForFlake so the ISO carries the
    # embedded repo and installer metadata from the current config repo.
    nix_expr="
      let
        self = builtins.getFlake (toString $(printf '%q' "$PROJECT_SNAPSHOT_DIR"));
        keystone = ${keystone_expr};
        installerTargets = self.outputs.installerTargets;
      in keystone.lib.mkInstallerIsoForFlake {
        sshKeys = $nix_keys_list;
        installedSshKeys = if ${DEV_MODE} then $nix_keys_list else [ ];
        adminUsername = \"$ADMIN_USERNAME\";
        adminName    = \"$ADMIN_NAME\";
        adminEmail   = \"$ADMIN_EMAIL\";
        repoPath = $(printf '%q' "$PROJECT_SNAPSHOT_DIR");
        repoName = \"$(basename "$PROJECT_DIR")\";
        inherit installerTargets;
        devMode = ${DEV_MODE};
      }
    "

    nix build \
        --impure \
        --expr "$nix_expr" \
        --out-link "$ISO_RESULT" \
        --print-build-logs

    iso_path="$(find "$ISO_RESULT/iso" -maxdepth 1 -name '*.iso' -print -quit 2>/dev/null || true)"
    if [[ -z "$iso_path" ]]; then
        log_error "Build succeeded but no ISO found in $ISO_RESULT/iso/"
        exit 1
    fi

    iso_size="$(du -h "$iso_path" | cut -f1)"
    log_ok "ISO built: $iso_path ($iso_size)"
    check_iso_artifact "$iso_path"
elif [[ "$UPDATE_KEYSTONE_INPUT" == "true" ]]; then
    log_warn "--update-keystone-input has no effect with --no-build; skipping input refresh."
fi

if [[ "$BOOT" == "false" ]]; then
    exit 0
fi

# ── locate the ISO ────────────────────────────────────────────────────────────

iso_path="$(find "$ISO_RESULT/iso" -maxdepth 1 -name '*.iso' -print -quit 2>/dev/null || true)"
if [[ -z "$iso_path" ]]; then
    log_error "No ISO found at $ISO_RESULT/iso/"
    log_error "Run without --no-build to build it first."
    exit 1
fi

check_iso_artifact "$iso_path"

# ── locate OVMF firmware ──────────────────────────────────────────────────────

find_ovmf() {
    # 1. Prefer nixpkgs OVMF for reproducible behavior. Some host-provided
    # OVMF builds fail to boot this ISO in QEMU and never touch the CD-ROM.
    local candidate store_path
    store_path="$(nix build nixpkgs#OVMF.fd --print-out-paths --no-link 2>/dev/null || true)"
    [[ -n "$store_path" ]] && candidate="$store_path/FV/OVMF.fd"
    [[ -f "${candidate:-}" ]] && { echo "$candidate"; return; }

    # 2. Fallback to host/system firmware paths
    candidate="$(find /run/current-system/sw/share -name 'OVMF.fd' 2>/dev/null | head -1 || true)"
    [[ -n "$candidate" ]] && { echo "$candidate"; return; }

    candidate="$(find /nix/store -maxdepth 3 -name 'OVMF.fd' 2>/dev/null | head -1 || true)"
    [[ -n "$candidate" ]] && { echo "$candidate"; return; }

    log_error "Could not locate OVMF firmware. Install it with:"
    log_error "  environment.systemPackages = [ pkgs.OVMF ];"
    exit 1
}

ovmf_path="$(find_ovmf)"
log_info "OVMF: $ovmf_path"

# ── ensure a writable install target disk exists ─────────────────────────────

ensure_vm_disk() {
    local disk_path="$1"
    local disk_size="$2"
    local disk_dir

    disk_dir="$(dirname "$disk_path")"
    mkdir -p "$disk_dir"

    if [[ ! -e "$disk_path" ]]; then
        log_info "Creating VM install disk: $disk_path ($disk_size)"
        truncate -s "$disk_size" "$disk_path"
    fi
}

ensure_vm_disk "$VM_DISK_PATH" "$VM_DISK_SIZE"
log_info "VM install disk: $VM_DISK_PATH"

# ── check port availability ───────────────────────────────────────────────────

if ss -tlnp 2>/dev/null | grep -q ":${SSH_PORT} " || \
   netstat -tlnp 2>/dev/null | grep -q ":${SSH_PORT} "; then
    log_warn "Port $SSH_PORT is already in use — choose another with --port"
    exit 1
fi

# ── boot the VM ──────────────────────────────────────────────────────────────

log_info "Starting QEMU with ISO: $(basename "$iso_path")"
log_info "SSH port forwarding: localhost:$SSH_PORT → VM:22"
echo >&2
log_ok "SSH command:"
if [[ "$DEV_MODE" == "true" && -f "$DEV_SSH_KEY_PATH" ]]; then
    log_ok "  ssh -i $DEV_SSH_KEY_PATH -p $SSH_PORT -o StrictHostKeyChecking=no ${ADMIN_USERNAME}@localhost"
else
    log_ok "  ssh -p $SSH_PORT -o StrictHostKeyChecking=no ${ADMIN_USERNAME}@localhost"
fi
echo >&2

QEMU_COMMON=(
    -enable-kvm
    -m "$QEMU_MEM"
    -smp "$QEMU_CPUS"
    -bios "$ovmf_path"
    -cdrom "$iso_path"
    -drive "if=none,id=installdisk,file=${VM_DISK_PATH},format=raw"
    -device "virtio-blk-pci,drive=installdisk,serial=keystone-test-disk"
    -netdev "user,id=net0,hostfwd=tcp:127.0.0.1:${SSH_PORT}-:22"
    -device "virtio-net-pci,netdev=net0,romfile="
)

if [[ "$HEADLESS" == "true" ]]; then
    # ── headless: background QEMU, poll for SSH ──────────────────────────────
    log_warn "Headless mode. Press Ctrl-C to stop the VM."
    echo >&2

    qemu-system-x86_64 "${QEMU_COMMON[@]}" -display none &
    QEMU_PID=$!
    trap 'kill "$QEMU_PID" 2>/dev/null; exit 0' INT TERM

    log_info "Waiting for SSH on port $SSH_PORT (timeout: ${SSH_WAIT_TIMEOUT}s)..."
    start_time="$(date +%s)"
    until ssh \
            "${SSH_IDENTITY_ARGS[@]}" \
            -p "$SSH_PORT" \
            -o StrictHostKeyChecking=no \
            -o ConnectTimeout=2 \
            -o LogLevel=ERROR \
            "${ADMIN_USERNAME}@localhost" \
            exit 0 2>/dev/null; do
        kill -0 "$QEMU_PID" 2>/dev/null || { log_error "QEMU exited unexpectedly."; exit 1; }
        now="$(date +%s)"
        if (( now - start_time >= SSH_WAIT_TIMEOUT )); then
            log_error "Timed out waiting for SSH after ${SSH_WAIT_TIMEOUT}s."
            log_error "Try GUI mode to inspect boot state: ./bin/test-iso --no-build"
            kill "$QEMU_PID" 2>/dev/null || true
            exit 1
        fi
        sleep 3
    done

    log_ok "SSH is up!"
    if [[ "$DEV_MODE" == "true" && -f "$DEV_SSH_KEY_PATH" ]]; then
        log_ok "  ssh -i $DEV_SSH_KEY_PATH -p $SSH_PORT -o StrictHostKeyChecking=no ${ADMIN_USERNAME}@localhost"
    else
        log_ok "  ssh -p $SSH_PORT -o StrictHostKeyChecking=no ${ADMIN_USERNAME}@localhost"
    fi
    echo >&2

    if [[ "$E2E_MODE" == "true" ]]; then
        E2E_EXPECT_PID=""
        run_e2e_installer
        if run_e2e_checkpoints; then
            log_ok "E2E test passed."
            kill "$E2E_EXPECT_PID" 2>/dev/null || true
            kill "$QEMU_PID" 2>/dev/null || true
            exit 0
        else
            log_error "E2E test failed."
            kill "$E2E_EXPECT_PID" 2>/dev/null || true
            kill "$QEMU_PID" 2>/dev/null || true
            exit 1
        fi
    fi

    log_warn "VM is running (PID $QEMU_PID). Press Ctrl-C to shut it down."
    wait "$QEMU_PID"
else
    # ── GUI: QEMU window ────────────────────────────────────────────────────
    log_warn "Close the QEMU window to stop."
    echo >&2
    exec qemu-system-x86_64 "${QEMU_COMMON[@]}"
fi
