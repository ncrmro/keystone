#!/usr/bin/env python3
"""
Keystone Post-Install Provisioner

Handles Secure Boot key generation and enrollment on an already-deployed NixOS system.

This script is designed to run AFTER nixos-anywhere deployment completes successfully.
It connects to the deployed system via SSH and provisions Secure Boot keys.

Workflow:
1. Deploy base system with systemd-boot (use bin/test-deployment)
2. Run this script to generate Secure Boot keys with sbctl
3. (Optional) Enroll keys into UEFI firmware
4. (Optional) Enable lanzaboote and rebuild system
5. Verify Secure Boot configuration

Zero external dependencies - uses only Python standard library.

Usage:
    ./bin/post-install-provisioner                # Generate keys only (safe)
    ./bin/post-install-provisioner --enroll       # Generate and enroll keys
    ./bin/post-install-provisioner --verify-only  # Check current status
    ./bin/post-install-provisioner --enroll --reboot  # Full automation
"""

import subprocess
import sys
import time
import argparse
from pathlib import Path

# ANSI color codes
RED = '\033[0;31m'
GREEN = '\033[0;32m'
YELLOW = '\033[1;33m'
BLUE = '\033[0;34m'
CYAN = '\033[0;36m'
NC = '\033[0m'  # No Color

# SSH connection settings
SSH_HOST = "localhost"
SSH_PORT = "22220"
SSH_USER = "root"
SSH_OPTS = "-o StrictHostKeyChecking=no -o ConnectTimeout=5 -o UserKnownHostsFile=/dev/null"

def print_step(step_num, total_steps, message):
    """Print a formatted step message"""
    print(f"\n{BLUE}[{step_num}/{total_steps}]{NC} {message}")

def print_success(message):
    """Print a success message"""
    print(f"{GREEN}✓{NC} {message}")

def print_error(message):
    """Print an error message"""
    print(f"{RED}✗{NC} {message}")

def print_warning(message):
    """Print a warning message"""
    print(f"{YELLOW}⚠{NC} {message}")

def print_info(message):
    """Print an info message"""
    print(f"{CYAN}ℹ{NC} {message}")

def run_command(cmd, check=True, capture=False, timeout=None):
    """Run a shell command"""
    try:
        if capture:
            result = subprocess.run(
                cmd,
                shell=True,
                check=check,
                capture_output=True,
                text=True,
                timeout=timeout
            )
            return result.stdout.strip()
        else:
            result = subprocess.run(cmd, shell=True, check=check, timeout=timeout)
            return result.returncode == 0
    except subprocess.CalledProcessError as e:
        if check:
            raise
        return False
    except subprocess.TimeoutExpired:
        print_error(f"Command timed out after {timeout} seconds")
        return False

def run_ssh_command(cmd, timeout=10, check=False):
    """Run a command on the deployed system via SSH

    Args:
        cmd: Command to execute on the remote system
        timeout: Command timeout in seconds
        check: Whether to raise on failure

    Returns:
        str: Command output (stdout) or empty string on failure
    """
    full_cmd = f"ssh -p {SSH_PORT} {SSH_OPTS} {SSH_USER}@{SSH_HOST} '{cmd}' 2>/dev/null"
    try:
        result = run_command(full_cmd, check=check, capture=True, timeout=timeout)
        return result if result else ""
    except:
        return ""

def check_system_connectivity():
    """Check if we can connect to the deployed system via SSH

    Returns:
        bool: True if SSH connection successful
    """
    print_info(f"Connecting to {SSH_USER}@{SSH_HOST}:{SSH_PORT}...")
    result = run_ssh_command("echo 'connected'", timeout=5)
    return result.strip() == "connected"

def check_uefi_mode():
    """Check if the system is running in UEFI mode

    Returns:
        bool: True if in UEFI mode, False otherwise
    """
    result = run_ssh_command("test -d /sys/firmware/efi && echo 'UEFI' || echo 'BIOS'")
    return result.strip() == "UEFI"

def detect_secure_boot_support():
    """Detect if the system firmware supports Secure Boot

    Returns:
        bool: True if Secure Boot variables are accessible
    """
    # Check for SecureBoot UEFI variable
    result = run_ssh_command(
        "test -f /sys/firmware/efi/efivars/SecureBoot-8be4df61-93ca-11d2-aa0d-00e098032b8c && echo 'SUPPORTED' || echo 'NOT_SUPPORTED'"
    )
    return result.strip() == "SUPPORTED"

def check_sbctl_available():
    """Check if sbctl is installed on the system

    Returns:
        bool: True if sbctl is available
    """
    result = run_ssh_command("command -v sbctl && echo 'FOUND' || echo 'NOT_FOUND'")
    return result.strip() == "FOUND"

def check_keys_exist():
    """Check if Secure Boot keys already exist in /var/lib/sbctl

    Returns:
        tuple: (exist: bool, key_files: list)
    """
    result = run_ssh_command("ls -1 /var/lib/sbctl/*.key 2>/dev/null || echo 'NONE'", timeout=5)

    if result.strip() == "NONE" or not result:
        return (False, [])

    key_files = [line.strip() for line in result.split('\n') if line.strip()]
    return (len(key_files) > 0, key_files)

def generate_secure_boot_keys():
    """Generate Secure Boot keys using sbctl

    This is the PRIMARY FUNCTION that creates PK, KEK, and db keys in /var/lib/sbctl.

    Returns:
        bool: True if keys generated successfully
    """
    print_info("Checking for existing keys...")

    # Check if keys already exist
    keys_exist, existing_keys = check_keys_exist()
    if keys_exist:
        print_warning("Secure Boot keys already exist:")
        for key_file in existing_keys:
            print(f"  {key_file}")
        print_info("Skipping key generation (use --force to regenerate)")
        return True

    print_info("Generating Secure Boot keys with sbctl...")
    print_info("This creates PK, KEK, and db keys in /var/lib/sbctl")

    # Run sbctl create-keys
    result = run_ssh_command("sbctl create-keys", timeout=30)

    if not result:
        print_error("Failed to generate Secure Boot keys")
        return False

    # Display output
    if result:
        for line in result.split('\n'):
            print(f"  {line}")

    print_success("Secure Boot keys generated successfully!")
    return True

def verify_key_generation():
    """Verify that all required Secure Boot keys were generated

    Returns:
        bool: True if all keys present
    """
    print_info("Verifying key generation...")

    # Expected keys in /var/lib/sbctl
    expected_keys = {
        "PK.key": "Platform Key",
        "PK.pem": "Platform Key (PEM)",
        "KEK.key": "Key Exchange Key",
        "KEK.pem": "Key Exchange Key (PEM)",
        "db.key": "Signature Database Key",
        "db.pem": "Signature Database Key (PEM)",
    }

    all_present = True
    for key_file, description in expected_keys.items():
        result = run_ssh_command(f"test -f /var/lib/sbctl/{key_file} && echo 'EXISTS' || echo 'MISSING'")
        if result.strip() == "EXISTS":
            print_success(f"{description} ({key_file})")
        else:
            print_error(f"{description} ({key_file}) - MISSING")
            all_present = False

    # Check sbctl status
    print_info("Checking sbctl status...")
    status_output = run_ssh_command("sbctl status", timeout=15)
    if status_output:
        print()
        for line in status_output.split('\n'):
            print(f"  {line}")
        print()

    return all_present

def enroll_keys(force=False):
    """Enroll Secure Boot keys into UEFI firmware using sbctl

    Args:
        force: If True, bypass confirmation prompts

    Returns:
        bool: True if enrollment successful
    """
    print_info("Enrolling Secure Boot keys into UEFI firmware...")
    print_warning("This will modify UEFI NVRAM variables")

    # Build enroll command
    cmd = "sbctl enroll-keys --microsoft"
    if force:
        cmd += " --yes-this-might-brick-my-machine"
        print_warning("Using --force flag (bypassing confirmations)")

    result = run_ssh_command(cmd, timeout=30)

    if not result:
        print_error("Failed to enroll Secure Boot keys")
        return False

    # Display output
    if result:
        for line in result.split('\n'):
            print(f"  {line}")

    print_success("Secure Boot keys enrolled successfully!")
    return True

def verify_enrollment():
    """Verify that Secure Boot keys were enrolled successfully

    Returns:
        bool: True if keys are enrolled (Setup Mode disabled)
    """
    print_info("Verifying key enrollment...")

    # Check Setup Mode via sysfs
    setup_mode_result = run_ssh_command(
        "cat /sys/firmware/efi/efivars/SetupMode-8be4df61-93ca-11d2-aa0d-00e098032b8c | od -An -t u1 | awk '{print $NF}'"
    )

    if setup_mode_result.strip() == "0":
        print_success("Setup Mode: Disabled (User Mode active)")
        print_success("Keys successfully enrolled in UEFI firmware")
        return True
    elif setup_mode_result.strip() == "1":
        print_warning("Setup Mode: Still enabled")
        print_info("Keys may not be enrolled yet")
        return False
    else:
        print_error("Could not determine Setup Mode status")
        return False

def verify_secure_boot_status():
    """Check comprehensive Secure Boot status

    Returns:
        tuple: (enabled: bool, details: dict)
    """
    print_info("Checking Secure Boot status...")

    details = {}

    # Check Setup Mode
    setup_mode = run_ssh_command(
        "cat /sys/firmware/efi/efivars/SetupMode-8be4df61-93ca-11d2-aa0d-00e098032b8c | od -An -t u1 | awk '{print $NF}'"
    )
    details['setup_mode'] = "User Mode (Keys Enrolled)" if setup_mode.strip() == "0" else "Setup Mode (No Keys)"

    # Check Secure Boot enabled
    secure_boot = run_ssh_command(
        "cat /sys/firmware/efi/efivars/SecureBoot-8be4df61-93ca-11d2-aa0d-00e098032b8c | od -An -t u1 | awk '{print $NF}'"
    )
    details['secure_boot_sysfs'] = "Enabled" if secure_boot.strip() == "1" else "Disabled"

    # Check with bootctl
    bootctl_result = run_ssh_command(
        "bootctl status | grep -i 'Secure Boot' | grep -q 'enabled' && echo 'ENABLED' || echo 'DISABLED'"
    )
    details['secure_boot_bootctl'] = bootctl_result.strip()

    # Display results
    print()
    for key, value in details.items():
        status_symbol = "✓" if "Enabled" in value or "User Mode" in value else "✗"
        print(f"  {status_symbol} {key.replace('_', ' ').title()}: {value}")
    print()

    is_enabled = secure_boot.strip() == "1"
    return (is_enabled, details)

def trigger_reboot():
    """Trigger a system reboot

    Returns:
        bool: True if reboot triggered
    """
    print_info("Triggering system reboot...")

    cmd = "nohup sh -c 'sleep 2 && reboot' >/dev/null 2>&1 &"
    run_ssh_command(cmd, timeout=5)

    print_success("Reboot triggered")
    print_info("System will reboot in 2 seconds...")
    time.sleep(5)

    return True

def wait_for_ssh(max_attempts=20, delay=3):
    """Wait for SSH to become available after reboot

    Args:
        max_attempts: Maximum number of connection attempts
        delay: Seconds between attempts

    Returns:
        bool: True if SSH connection restored
    """
    print_info(f"Waiting for system to come back online (max {max_attempts * delay} seconds)...")

    for attempt in range(max_attempts):
        try:
            result = run_ssh_command("echo 'ready'", timeout=3)
            if result.strip() == "ready":
                print_success("SSH connection restored")
                return True
        except:
            pass

        if attempt < max_attempts - 1:
            print(f"  Attempt {attempt + 1}/{max_attempts}...", end='\r')
            time.sleep(delay)

    print_error("System did not come back online")
    return False

def main():
    """Main provisioner workflow"""
    parser = argparse.ArgumentParser(
        description="Keystone Post-Install Provisioner - Secure Boot key generation and enrollment",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Examples:
  %(prog)s                    Generate Secure Boot keys only
  %(prog)s --verify-only      Check current Secure Boot status
  %(prog)s --enroll           Generate and enroll keys
  %(prog)s --enroll --force   Enroll keys without confirmation
  %(prog)s --enroll --reboot  Full automation with reboot
        """
    )

    parser.add_argument('--verify-only', action='store_true',
                       help='Check current Secure Boot status without making changes')
    parser.add_argument('--enroll', action='store_true',
                       help='Enroll keys into UEFI firmware after generation')
    parser.add_argument('--force', action='store_true',
                       help='Bypass confirmation prompts (use with --enroll)')
    parser.add_argument('--reboot', action='store_true',
                       help='Automatically reboot after enrollment (use with --enroll)')

    args = parser.parse_args()

    # Print banner
    print("=" * 60)
    print(f"{CYAN}Keystone Post-Install Provisioner{NC}")
    print("=" * 60)
    print(f"Mode: {'Verify Only' if args.verify_only else 'Generate Keys' + (' + Enroll' if args.enroll else '')}")
    print(f"Target: {SSH_USER}@{SSH_HOST}:{SSH_PORT}")
    print()

    # Calculate total steps
    total_steps = 3  # connectivity, UEFI check, status check
    if args.verify_only:
        total_steps = 2  # Just connectivity and status
    else:
        total_steps = 5  # connectivity, UEFI, generate, verify, status
        if args.enroll:
            total_steps += 2  # enroll, verify enrollment
        if args.reboot:
            total_steps += 2  # reboot, wait for SSH

    current_step = 0

    # Step: Check connectivity
    current_step += 1
    print_step(current_step, total_steps, "Checking system connectivity")

    if not check_system_connectivity():
        print_error("Cannot connect to deployed system")
        print_info(f"Ensure the system is running and accessible at {SSH_HOST}:{SSH_PORT}")
        print_info("You may need to remove old host keys:")
        print(f"  ssh-keygen -R '[{SSH_HOST}]:{SSH_PORT}'")
        return 1

    print_success("SSH connection established")

    # Verify-only mode
    if args.verify_only:
        current_step += 1
        print_step(current_step, total_steps, "Checking Secure Boot status")

        if not check_uefi_mode():
            print_error("System is not booted in UEFI mode")
            return 1

        print_success("UEFI mode confirmed")

        if not detect_secure_boot_support():
            print_warning("Secure Boot variables not accessible")
            print_info("System may not support Secure Boot")
            return 1

        print_success("Secure Boot support detected")

        # Check current status
        enabled, details = verify_secure_boot_status()

        # Check if keys exist
        keys_exist, key_files = check_keys_exist()
        if keys_exist:
            print()
            print_info("Existing Secure Boot keys found:")
            for key_file in key_files:
                print(f"  {key_file}")
        else:
            print()
            print_warning("No Secure Boot keys found in /var/lib/sbctl")
            print_info("Run without --verify-only to generate keys")

        return 0

    # Step: Check UEFI mode and Secure Boot support
    current_step += 1
    print_step(current_step, total_steps, "Checking UEFI mode and Secure Boot support")

    if not check_uefi_mode():
        print_error("System is not booted in UEFI mode")
        print_info("Secure Boot requires UEFI firmware")
        return 1

    print_success("UEFI mode confirmed")

    if not detect_secure_boot_support():
        print_warning("Secure Boot variables not accessible")
        print_info("VM firmware may not support Secure Boot")
        print_info("For QEMU/KVM, ensure OVMF with secureBoot=true is used")
        return 1

    print_success("Secure Boot support detected")

    # Check sbctl availability
    if not check_sbctl_available():
        print_error("sbctl command not found on deployed system")
        print_info("Ensure sbctl is in environment.systemPackages")
        return 1

    print_success("sbctl is available")

    # Step: Generate keys
    current_step += 1
    print_step(current_step, total_steps, "Generating Secure Boot keys")

    if not generate_secure_boot_keys():
        print_error("Failed to generate Secure Boot keys")
        return 1

    # Step: Verify key generation
    current_step += 1
    print_step(current_step, total_steps, "Verifying key generation")

    if not verify_key_generation():
        print_error("Key generation verification failed")
        return 1

    print_success("All required keys present")

    # Step: Enroll keys (if requested)
    if args.enroll:
        current_step += 1
        print_step(current_step, total_steps, "Enrolling Secure Boot keys")

        if not enroll_keys(force=args.force):
            print_error("Key enrollment failed")
            return 1

        # Step: Verify enrollment
        current_step += 1
        print_step(current_step, total_steps, "Verifying key enrollment")

        if not verify_enrollment():
            print_warning("Enrollment verification inconclusive")
            print_info("Keys may need additional configuration or UEFI settings")

        # Step: Reboot (if requested)
        if args.reboot:
            current_step += 1
            print_step(current_step, total_steps, "Rebooting system")

            if not trigger_reboot():
                print_error("Failed to trigger reboot")
                return 1

            current_step += 1
            print_step(current_step, total_steps, "Waiting for system to come back online")

            if not wait_for_ssh():
                print_error("System did not come back online after reboot")
                print_info("Check VM console or logs")
                return 1

            print_success("System rebooted successfully")

    # Step: Final status check
    current_step += 1
    print_step(current_step, total_steps, "Final Secure Boot status")

    enabled, details = verify_secure_boot_status()

    # Print summary
    print()
    print("=" * 60)
    if enabled:
        print(f"{GREEN}✓ Secure Boot is ENABLED!{NC}")
    elif args.enroll:
        print(f"{YELLOW}⚠ Secure Boot provisioned but not yet enabled{NC}")
    else:
        print(f"{GREEN}✓ Secure Boot keys generated!{NC}")
    print("=" * 60)
    print()

    # Next steps guidance
    if not args.enroll:
        print("Next steps:")
        print("  1. Review keys: ssh -p 22220 root@localhost 'ls -la /var/lib/sbctl'")
        print("  2. Enroll keys: ./bin/post-install-provisioner --enroll")
        print("  3. Enable lanzaboote in your NixOS configuration")
        print("  4. Rebuild and reboot the system")
        print()
    elif not enabled:
        print("Next steps:")
        print("  1. Enable lanzaboote in your NixOS configuration:")
        print("       boot.loader.systemd-boot.enable = false;")
        print("       boot.lanzaboote.enable = true;")
        print("       boot.lanzaboote.pkiBundle = \"/var/lib/sbctl\";")
        print("  2. Rebuild system: nixos-rebuild switch")
        print("  3. Reboot and verify: sbctl status")
        print()
    else:
        print("Secure Boot is fully operational!")
        print()

    return 0

if __name__ == "__main__":
    try:
        sys.exit(main())
    except KeyboardInterrupt:
        print()
        print_warning("Provisioning interrupted by user")
        sys.exit(130)
    except Exception as e:
        print_error(f"Unexpected error: {e}")
        import traceback
        traceback.print_exc()
        sys.exit(1)
