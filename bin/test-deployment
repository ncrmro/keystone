#!/usr/bin/env python3
"""
Keystone Deployment Test Script

Automates the complete VM deployment testing workflow:
- VM lifecycle management (start, stop, hard reset)
- ISO building (optional)
- nixos-anywhere deployment
- Secure Boot automation with lanzaboote (optional)
- Post-deployment verification

Zero external dependencies - uses only Python standard library.

Usage:
    ./bin/test-deployment                    # Normal test run
    ./bin/test-deployment --rebuild-iso      # Rebuild ISO first
    ./bin/test-deployment --hard-reset       # Force kill VM and clean artifacts
    ./bin/test-deployment --skip-secureboot  # Skip Secure Boot phases
    ./bin/test-deployment --rebuild-iso --hard-reset  # Full clean test
"""

import subprocess
import sys
import time
import os
import signal
from pathlib import Path
from typing import Tuple

# ANSI color codes
RED = '\033[0;31m'
GREEN = '\033[0;32m'
YELLOW = '\033[1;33m'
BLUE = '\033[0;34m'
CYAN = '\033[0;36m'
NC = '\033[0m'  # No Color

def print_step(step_num, total_steps, message):
    """Print a formatted step message"""
    print(f"\n{BLUE}[{step_num}/{total_steps}]{NC} {message}")

def print_success(message):
    """Print a success message"""
    print(f"{GREEN}✓{NC} {message}")

def print_error(message):
    """Print an error message"""
    print(f"{RED}✗{NC} {message}")

def print_warning(message):
    """Print a warning message"""
    print(f"{YELLOW}⚠{NC} {message}")

def print_info(message):
    """Print an info message"""
    print(f"{CYAN}ℹ{NC} {message}")

def run_command(cmd, check=True, capture=False, timeout=None):
    """Run a shell command"""
    try:
        if capture:
            result = subprocess.run(
                cmd,
                shell=True,
                check=check,
                capture_output=True,
                text=True,
                timeout=timeout
            )
            return result.stdout.strip()
        else:
            result = subprocess.run(cmd, shell=True, check=check, timeout=timeout)
            return result.returncode == 0
    except subprocess.CalledProcessError as e:
        if check:
            raise
        return False
    except subprocess.TimeoutExpired:
        print_error(f"Command timed out after {timeout} seconds")
        return False

def find_vm_processes():
    """Find running quickemu or qemu VM processes for server"""
    try:
        # Match both quickemu processes and direct qemu processes with server name
        output = run_command("pgrep -f '(quickemu.*server|qemu.*-name server)'", check=False, capture=True)
        if output:
            return [int(pid) for pid in output.split('\n') if pid.strip()]
        return []
    except:
        return []

def kill_vm_processes(hard=False):
    """Kill VM processes"""
    pids = find_vm_processes()
    if not pids:
        print_info("No VM processes found")
        return True

    signal_type = signal.SIGKILL if hard else signal.SIGTERM
    signal_name = "SIGKILL" if hard else "SIGTERM"

    for pid in pids:
        try:
            print_info(f"Sending {signal_name} to process {pid}")
            os.kill(pid, signal_type)
            time.sleep(0.5)
        except ProcessLookupError:
            pass  # Already dead
        except PermissionError:
            print_error(f"Permission denied to kill process {pid}")
            return False

    # Wait for processes to die
    for i in range(10):
        remaining = find_vm_processes()
        if not remaining:
            print_success("All VM processes terminated")
            # Extra cooldown to ensure disk is released
            print_info("Waiting for disk to be fully released...")
            time.sleep(3)
            return True
        time.sleep(0.5)

    print_error("Some VM processes still running")
    return False

def clean_vm_artifacts():
    """Remove VM disk and runtime files, and restore ISO line in config"""
    # Sync filesystems to ensure all writes are flushed
    run_command("sync", check=False)
    time.sleep(1)

    # Restore ISO line in config if it was commented out
    config_file = Path("vms/server.conf")
    if config_file.exists():
        config_content = config_file.read_text()
        if '#iso="keystone-installer.iso"' in config_content:
            config_content = config_content.replace('#iso="keystone-installer.iso"', 'iso="keystone-installer.iso"')
            config_file.write_text(config_content)
            print_info("Restored ISO line in VM configuration")

    vm_dir = Path("vms/server")
    if not vm_dir.exists():
        print_info("VM directory doesn't exist, nothing to clean")
        return True

    artifacts = [
        "disk.qcow2",
        "OVMF_VARS.fd",
        "*.pid",
        "*.socket",
        "*.log",
        "*.ports"
    ]

    removed = []
    for pattern in artifacts:
        for file in vm_dir.glob(pattern):
            try:
                file.unlink()
                removed.append(file.name)
            except Exception as e:
                print_warning(f"Could not remove {file}: {e}")

    if removed:
        print_success(f"Removed {len(removed)} artifact(s): {', '.join(removed)}")
    else:
        print_info("No artifacts to clean")

    return True

def rebuild_iso():
    """Rebuild the Keystone ISO with SSH keys"""
    print_info("Building ISO with SSH key injection...")
    print_info("This may take 2-5 minutes...")

    ssh_key_file = Path.home() / ".ssh" / "id_ed25519.pub"
    if not ssh_key_file.exists():
        print_error(f"SSH key not found: {ssh_key_file}")
        return False

    cmd = f"./bin/build-iso --ssh-key {ssh_key_file}"
    success = run_command(cmd, timeout=300)

    if success:
        print_success("ISO built successfully")
        return True
    else:
        print_error("ISO build failed")
        return False

def patch_vm_script_remove_snapshot():
    """Remove snapshot mode from VM script (makes disk read-only)"""
    script_file = Path("vms/server/server.sh")
    if not script_file.exists():
        return False

    content = script_file.read_text()

    # Check if already patched
    if "-snapshot" not in content:
        print_info("VM script already patched (snapshot removed)")
        return True

    # Remove snapshot mode
    patched = content.replace("    -snapshot \\\n", "")

    if patched != content:
        script_file.write_text(patched)
        print_success("Patched VM script: removed snapshot mode")
        return True

    print_info("VM script doesn't need patching")
    return True

def send_password_to_serial(password="keystone"):
    """Send password to VM serial console via Unix socket"""
    socket_path = Path("vms/server/server-serial.socket")

    if not socket_path.exists():
        print_error(f"Serial socket not found: {socket_path}")
        return False

    print_info(f"Sending password to serial console...")
    # Use socat to send password to the serial socket
    cmd = f"echo '{password}' | socat - UNIX-CONNECT:{socket_path}"
    result = run_command(cmd, check=False, timeout=5)

    if result:
        print_success("Password sent to serial console")
        return True
    else:
        print_error("Failed to send password to serial console")
        return False

# Secure Boot helper functions

def check_uefi_mode() -> bool:
    """Check if the VM is running in UEFI mode

    Returns:
        bool: True if in UEFI mode, False otherwise
    """
    result = run_ssh_command_on_vm("test -d /sys/firmware/efi && echo 'UEFI' || echo 'BIOS'")
    return result.strip() == "UEFI"

def detect_secure_boot_support() -> bool:
    """Detect if the VM firmware supports Secure Boot

    Returns:
        bool: True if Secure Boot variables are accessible, False otherwise
    """
    # Check for SecureBoot UEFI variable
    result = run_ssh_command_on_vm(
        "test -f /sys/firmware/efi/efivars/SecureBoot-8be4df61-93ca-11d2-aa0d-00e098032b8c && echo 'SUPPORTED' || echo 'NOT_SUPPORTED'"
    )
    return result.strip() == "SUPPORTED"

def check_secure_boot_capability() -> Tuple[bool, str]:
    """Check if Secure Boot is supported and can be configured

    Returns:
        tuple: (supported: bool, message: str)
    """
    print_info("Verifying UEFI mode and Secure Boot support...")

    # Check UEFI mode
    if not check_uefi_mode():
        return (False, "System is not booted in UEFI mode")

    print_success("UEFI mode confirmed")

    # Check Secure Boot variable support
    if not detect_secure_boot_support():
        return (False, "Secure Boot variables not accessible")

    print_success("Secure Boot variables accessible")

    return (True, "Secure Boot capability confirmed")

def enroll_secure_boot_keys() -> bool:
    """Enroll Secure Boot keys using sbctl

    The lanzaboote module with enrollKeys=true should automatically enroll keys
    during the first boot. This function verifies the enrollment.

    Returns:
        bool: True if keys enrolled successfully, False otherwise
    """
    print_info("Checking Secure Boot key enrollment status...")

    # Check if sbctl is available
    sbctl_check = run_ssh_command_on_vm("command -v sbctl && echo 'FOUND' || echo 'NOT_FOUND'")
    if sbctl_check.strip() != "FOUND":
        print_error("sbctl command not found on deployed system")
        return False

    # Check current sbctl status
    status_output = run_ssh_command_on_vm("sbctl status", timeout=15)
    print_info("Current sbctl status:")
    if status_output:
        for line in status_output.split('\n'):
            print(f"  {line}")

    # Check if Setup Mode is disabled (keys enrolled)
    setup_mode_check = run_ssh_command_on_vm(
        "sbctl status | grep -i 'Setup Mode' | grep -q 'Disabled' && echo 'ENROLLED' || echo 'NOT_ENROLLED'"
    )

    if setup_mode_check.strip() == "ENROLLED":
        print_success("Secure Boot keys already enrolled")
        print_success("Setup Mode disabled (User Mode active)")
        return True

    # If not enrolled and lanzaboote has enrollKeys=true, it should have been automatic
    print_warning("Keys not yet enrolled - this may require manual enrollment or UEFI settings")
    print_info("With lanzaboote enrollKeys=true, keys should enroll on first boot")

    return False

def trigger_reboot_after_enrollment() -> bool:
    """Trigger a system reboot after Secure Boot key enrollment

    Returns:
        bool: True if reboot triggered successfully, False otherwise
    """
    print_info("Triggering system reboot...")

    # Trigger reboot via SSH
    cmd = "nohup sh -c 'sleep 2 && reboot' >/dev/null 2>&1 &"
    run_ssh_command_on_vm(cmd, timeout=5)

    print_success("Reboot triggered")

    # Wait for system to go down
    print_info("Waiting for system to reboot (60 seconds)...")
    time.sleep(60)

    # Wait for SSH to come back up
    print_info("Waiting for SSH to become available...")
    if wait_for_ssh(max_attempts=15, delay=3):
        print_success("System rebooted successfully")
        return True
    else:
        print_error("System did not come back online after reboot")
        return False

# Secure Boot verification functions (Phase 4 - US2)

def check_secure_boot_status() -> bool:
    """Check if Secure Boot is enabled via sysfs

    Returns:
        bool: True if Secure Boot is enabled, False otherwise
    """
    result = run_ssh_command_on_vm(
        "cat /sys/firmware/efi/efivars/SecureBoot-8be4df61-93ca-11d2-aa0d-00e098032b8c | od -An -t u1 | awk '{print $NF}'"
    )
    return result.strip() == "1"

def verify_setup_mode_disabled() -> bool:
    """Verify that Setup Mode is disabled (keys enrolled)

    Returns:
        bool: True if Setup Mode is disabled, False otherwise
    """
    result = run_ssh_command_on_vm(
        "cat /sys/firmware/efi/efivars/SetupMode-8be4df61-93ca-11d2-aa0d-00e098032b8c | od -An -t u1 | awk '{print $NF}'"
    )
    # Setup Mode: 0 = User Mode (keys enrolled), 1 = Setup Mode
    return result.strip() == "0"

def verify_secure_boot_enabled() -> bool:
    """Verify Secure Boot is enabled using bootctl

    Returns:
        bool: True if bootctl confirms Secure Boot enabled, False otherwise
    """
    result = run_ssh_command_on_vm("bootctl status | grep -i 'Secure Boot' | grep -q 'enabled' && echo 'ENABLED' || echo 'DISABLED'")
    return result.strip() == "ENABLED"

def verify_boot_files_signed() -> bool:
    """Verify boot files are properly signed using sbctl

    Returns:
        bool: True if all boot files are signed, False otherwise
    """
    result = run_ssh_command_on_vm("sbctl verify 2>&1 | grep -q 'Verifying' && echo 'SIGNED' || echo 'UNSIGNED'")
    return result.strip() == "SIGNED"

def verify_secure_boot() -> bool:
    """Run all Secure Boot verification checks

    Returns:
        bool: True if all checks pass, False otherwise
    """
    print_info("Running Secure Boot verification checks...")

    checks = [
        ("Setup Mode status: disabled", verify_setup_mode_disabled),
        ("Secure Boot enabled (sysfs)", check_secure_boot_status),
        ("Secure Boot enabled (bootctl)", verify_secure_boot_enabled),
        ("Boot files properly signed", verify_boot_files_signed),
    ]

    all_passed = True
    for check_name, check_func in checks:
        if check_func():
            print_success(check_name)
        else:
            print_error(check_name)
            all_passed = False

    return all_passed

def should_skip_secure_boot(skip_secureboot_flag: bool, secure_boot_capable: bool) -> Tuple[bool, str]:
    """Determine if Secure Boot phases should be skipped

    This function centralizes the decision logic for whether to skip Secure Boot
    phases based on user flags and platform capability detection.

    Args:
        skip_secureboot_flag: User explicitly requested to skip via --skip-secureboot
        secure_boot_capable: Platform has Secure Boot capability (UEFI + variables)

    Returns:
        tuple: (should_skip: bool, reason: str)
    """
    if skip_secureboot_flag:
        return (True, "User requested skip with --skip-secureboot flag")

    if not secure_boot_capable:
        return (True, "Platform does not support Secure Boot")

    return (False, "Secure Boot phases will proceed")

def start_vm():
    """Start the VM"""
    print_info("Starting VM from ISO...")

    # Use make to start the VM - it handles disk creation and script generation
    print_info("Starting VM using make vm-server...")
    result = run_command("make vm-server", check=False, timeout=30)

    if not result:
        print_error("Failed to start VM")
        return False

    print_info("Waiting for VM to boot (30 seconds)...")
    time.sleep(30)

    return True

def run_ssh_command_on_vm(cmd, timeout=10, check=False):
    """Run a command on the deployed VM via SSH

    This is a dedicated helper for running commands on the deployed system
    at localhost:22220. It properly handles SSH options and error cases.

    Args:
        cmd: Command to execute on the VM
        timeout: Command timeout in seconds
        check: Whether to raise on failure

    Returns:
        str: Command output (stdout) or empty string on failure
    """
    ssh_opts = "-p 22220 -o ConnectTimeout=5 -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null"
    full_cmd = f"ssh {ssh_opts} root@localhost '{cmd}' 2>/dev/null"
    try:
        result = run_command(full_cmd, check=check, capture=True, timeout=timeout)
        return result if result else ""
    except:
        return ""

def wait_for_ssh(max_attempts=10, delay=3):
    """Wait for SSH to become available"""
    print_info(f"Waiting for SSH access (max {max_attempts * delay} seconds)...")

    for attempt in range(max_attempts):
        try:
            result = run_ssh_command_on_vm("echo ready", timeout=5)
            if result == "ready":
                print_success("SSH is ready")
                return True
        except:
            pass

        if attempt < max_attempts - 1:
            print(f"  Attempt {attempt + 1}/{max_attempts}...", end='\r')
            time.sleep(delay)

    print_error("SSH never became available")
    return False

def prebuild_system_config():
    """Pre-build the system configuration on the host to populate Nix cache"""
    print_info("Pre-building system configuration on host...")
    print_info("This ensures all packages are cached locally before deployment")

    # Build the full system configuration including all dependencies
    cmd = "nix build .#nixosConfigurations.test-server.config.system.build.toplevel --no-link"
    success = run_command(cmd, timeout=600)

    if success:
        print_success("System configuration pre-built successfully")
        return True
    else:
        print_error("Failed to pre-build system configuration")
        return False

def deploy_to_vm():
    """Deploy using nixos-anywhere with manual cleanup and reboot"""
    print_info("Starting nixos-anywhere deployment...")
    print_info("This will take 5-10 minutes...")
    print_warning("You may need to interact with the deployment (confirmations, etc.)")

    # Use --no-reboot to allow manual cleanup before rebooting
    # Use --build-on local to ensure builds happen on host and use the cache
    cmd = "nix run nixpkgs#nixos-anywhere -- --flake .#test-server root@localhost --ssh-port 22220 --no-reboot --build-on local"
    success = run_command(cmd, timeout=600)

    if not success:
        print_error("Deployment failed")
        return False

    print_success("Deployment phase completed!")

    # Now perform manual cleanup to prevent hanging during pool export
    print_info("Performing cleanup before reboot...")

    cleanup_cmd = """ssh -p 22220 -o StrictHostKeyChecking=no root@localhost '
        # Unmount all ZFS filesystems first
        if zpool list rpool >/dev/null 2>&1; then
            echo "Unmounting ZFS filesystems..."
            # Change to root to ensure we are not in /mnt
            cd /
            # Unmount all filesystems under /mnt
            umount -R /mnt 2>/dev/null || true
        fi

        # Close the credstore LUKS device (must be done before pool export)
        if cryptsetup status credstore >/dev/null 2>&1; then
            echo "Closing credstore LUKS device..."
            cryptsetup close credstore
        fi

        # Now safely export the ZFS pool
        if zpool list rpool >/dev/null 2>&1; then
            echo "Exporting ZFS pool..."
            zpool export rpool
        fi

        # Trigger reboot
        echo "Rebooting system..."
        nohup sh -c "sleep 2 && reboot" >/dev/null 2>&1 &
    '"""

    cleanup_success = run_command(cleanup_cmd, check=False, timeout=30)

    if cleanup_success:
        print_success("Cleanup and reboot triggered successfully!")
    else:
        print_warning("Cleanup command had issues, but system may still reboot")

    # Wait for system to reboot
    print_info("Waiting for system to reboot...")
    time.sleep(5)

    return True

def remove_iso_and_reboot():
    """Remove ISO from VM config and restart to boot from disk"""
    print_info("Exporting ZFS pool before VM restart...")

    # Export the pool cleanly to avoid import conflicts
    export_cmd = """ssh -p 22220 -o StrictHostKeyChecking=no root@localhost '
        if zpool list rpool >/dev/null 2>&1; then
            echo "Exporting ZFS pool rpool..."
            zpool export rpool
            echo "Pool exported successfully"
        else
            echo "Pool not imported, nothing to export"
        fi
    ' 2>/dev/null"""

    export_result = run_command(export_cmd, check=False, timeout=10)
    if export_result:
        print_success("ZFS pool exported successfully")
    else:
        print_warning("Could not export pool (may not be mounted)")

    print_info("Removing ISO from VM configuration...")

    config_file = Path("vms/server.conf")
    if not config_file.exists():
        print_error("VM config file not found")
        return False

    # Read current config
    config_content = config_file.read_text()

    # Comment out the ISO line
    new_config = config_content.replace('iso="keystone-installer.iso"', '#iso="keystone-installer.iso"')

    # Write back
    config_file.write_text(new_config)
    print_success("ISO removed from configuration")

    # Kill VM
    print_info("Stopping VM...")
    if not kill_vm_processes(hard=True):
        print_warning("Failed to stop VM cleanly")

    # Remove generated script so it regenerates without ISO
    script_file = Path("vms/server/server.sh")
    if script_file.exists():
        script_file.unlink()
        print_success("Removed old startup script")

    # Restart VM - use make which handles everything
    print_info("Restarting VM to boot from installed disk...")
    run_command("make vm-server", check=False, timeout=30)

    # Wait for boot to reach LUKS password prompt
    print_info("Waiting for LUKS password prompt (15 seconds)...")
    time.sleep(15)

    # Automatically send the LUKS password
    if not send_password_to_serial("keystone"):
        print_warning("Failed to send password, but continuing...")

    # Wait for unlock to complete and system to finish booting
    print_info("Waiting for system to finish booting (25 seconds)...")
    time.sleep(25)

    return True

def verify_deployment(include_secureboot=False):
    """Run deployment verification checks

    Args:
        include_secureboot: If True, include Secure Boot checks in verification

    Returns:
        bool: True if all checks pass, False otherwise
    """
    print_info("Waiting for deployed system to finish booting (30 seconds)...")
    time.sleep(30)

    print_info("Running verification checks...")

    # Basic deployment checks
    checks = [
        ("SSH connectivity", lambda: run_ssh_command_on_vm("echo ok", timeout=5) == "ok"),
        ("Hostname", lambda: len(run_ssh_command_on_vm("hostname", timeout=5)) > 0),
        ("ZFS pool status", lambda: "ONLINE" in run_ssh_command_on_vm("zpool status rpool", timeout=10)),
        ("SSH service active", lambda: run_ssh_command_on_vm("systemctl is-active sshd", timeout=5) == "active"),
    ]

    # Add Secure Boot checks if requested
    if include_secureboot:
        checks.extend([
            ("Secure Boot: Setup Mode disabled", verify_setup_mode_disabled),
            ("Secure Boot: Enabled (sysfs)", check_secure_boot_status),
            ("Secure Boot: sbctl confirms", lambda: "enabled" in run_ssh_command_on_vm("sbctl status | grep -i 'secure boot'", timeout=10).lower()),
        ])

    passed = 0
    failed = 0

    for check_name, check_func in checks:
        try:
            if check_func():
                print_success(f"{check_name}")
                passed += 1
            else:
                print_error(f"{check_name}")
                failed += 1
        except Exception as e:
            print_error(f"{check_name} (error: {e})")
            failed += 1

    print(f"\nPassed: {GREEN}{passed}{NC}, Failed: {RED}{failed}{NC}")

    return failed == 0

def ensure_vm_config():
    """Ensure VM config exists, create from example if needed"""
    config_file = Path("vms/server.conf")
    example_file = Path("vms/server.conf.example")

    if not config_file.exists():
        if not example_file.exists():
            print_error("Neither vms/server.conf nor vms/server.conf.example found!")
            print_info("Please ensure you're in the project root directory")
            return False

        print_info("Creating vms/server.conf from example...")
        config_file.write_text(example_file.read_text())
        print_success("Created vms/server.conf")

    return True

def main():
    """Main test workflow"""
    # Parse arguments
    rebuild_iso_flag = "--rebuild-iso" in sys.argv
    hard_reset_flag = "--hard-reset" in sys.argv
    skip_secureboot_flag = "--skip-secureboot" in sys.argv
    help_flag = "--help" in sys.argv or "-h" in sys.argv

    if help_flag:
        print(__doc__)
        return 0

    # Ensure VM config exists
    if not ensure_vm_config():
        return 1

    print("=" * 60)
    print(f"{CYAN}Keystone Deployment Test{NC}")
    print("=" * 60)
    print(f"Rebuild ISO: {rebuild_iso_flag}")
    print(f"Hard Reset: {hard_reset_flag}")
    print(f"Skip Secure Boot: {skip_secureboot_flag}")
    print()

    # Base steps: VM stop, VM start, SSH wait, Pre-build, Deploy, Reboot to disk, Verification
    total_steps = 7
    if rebuild_iso_flag:
        total_steps += 1
    if hard_reset_flag:
        total_steps += 2
    # Secure Boot adds 3 steps: capability check, enrollment, verification
    # We'll dynamically adjust total_steps if Secure Boot is skipped or unsupported

    current_step = 0
    secure_boot_supported = False  # Track if we should attempt Secure Boot phases
    secure_boot_tested = False  # Track if Secure Boot was actually tested
    secure_boot_status_msg = "Not tested"  # Track status message for summary

    # Step: Hard reset if requested
    if hard_reset_flag:
        current_step += 1
        print_step(current_step, total_steps, "Hard resetting VM")

        if not kill_vm_processes(hard=True):
            print_error("Failed to kill VM processes")
            return 1

        current_step += 1
        print_step(current_step, total_steps, "Cleaning VM artifacts")

        if not clean_vm_artifacts():
            print_error("Failed to clean VM artifacts")
            return 1
    else:
        # Graceful stop
        current_step += 1
        print_step(current_step, total_steps, "Stopping existing VM")

        if not kill_vm_processes(hard=False):
            print_warning("Failed graceful stop, trying hard kill...")
            kill_vm_processes(hard=True)

    # Step: Rebuild ISO if requested
    if rebuild_iso_flag:
        current_step += 1
        print_step(current_step, total_steps, "Rebuilding ISO")

        if not rebuild_iso():
            return 1

    # Step: Start VM
    current_step += 1
    print_step(current_step, total_steps, "Starting VM from ISO")

    if not start_vm():
        return 1

    # Step: Wait for SSH
    current_step += 1
    print_step(current_step, total_steps, "Waiting for SSH access")

    if not wait_for_ssh():
        print_error("VM did not become accessible")
        return 1

    # Step: Pre-build system configuration
    current_step += 1
    print_step(current_step, total_steps, "Pre-building system configuration on host")

    if not prebuild_system_config():
        print_error("Failed to pre-build system configuration")
        return 1

    # Step: Deploy
    current_step += 1
    print_step(current_step, total_steps, "Deploying with nixos-anywhere")

    if not deploy_to_vm():
        print_error("Deployment failed - check output above")
        return 1

    # Step: Remove ISO and reboot to installed system
    current_step += 1
    print_step(current_step, total_steps, "Removing ISO and rebooting to disk")

    if not remove_iso_and_reboot():
        print_error("Failed to remove ISO and reboot")
        return 1

    # Secure Boot phases (Phase 3-4: User Stories 1-2)
    if not skip_secureboot_flag:
        # Adjust total_steps to include Secure Boot phases
        total_steps += 3

        # Step: Check Secure Boot capability
        current_step += 1
        print_step(current_step, total_steps, "Checking Secure Boot capability")

        supported, message = check_secure_boot_capability()
        if not supported:
            print_warning(f"UEFI Secure Boot not supported: {message}")
            print_info("Skipping Secure Boot enrollment and verification")
            # Remove the Secure Boot steps from total_steps since we're skipping
            total_steps -= 2
            secure_boot_status_msg = f"Skipped - {message}"
        else:
            print_success(message)
            secure_boot_supported = True
            secure_boot_tested = True

            # Step: Verify Secure Boot enrollment
            current_step += 1
            print_step(current_step, total_steps, "Verifying Secure Boot key enrollment")

            if not enroll_secure_boot_keys():
                print_warning("Secure Boot keys not enrolled automatically")
                print_info("This may be expected - keys might enroll after UEFI settings change")
                # Continue anyway - verification step will show actual status

            # Step: Verify Secure Boot configuration
            current_step += 1
            print_step(current_step, total_steps, "Verifying Secure Boot configuration")

            if not verify_secure_boot():
                print_warning("Some Secure Boot verification checks failed")
                print_info("This may be expected if Secure Boot is not enabled in UEFI firmware")
                print_info("Keys are enrolled, but Secure Boot may need to be enabled manually in UEFI settings")
                secure_boot_status_msg = "Tested - Keys enrolled, but not fully enabled"
            else:
                print_success("Secure Boot is fully configured and functional!")
                secure_boot_status_msg = "Fully configured and functional"
    else:
        print_info("Skipping Secure Boot phases (--skip-secureboot flag)")
        secure_boot_status_msg = "Skipped - User requested via --skip-secureboot"

    # Step: Verify
    current_step += 1
    print_step(current_step, total_steps, "Verifying deployment")

    if not verify_deployment(include_secureboot=secure_boot_supported):
        print_warning("Some verification checks failed")
        print_info("You can still SSH to the VM: ssh -p 22220 root@localhost")
    else:
        print()
        print("=" * 60)
        print(f"{GREEN}✓ All tests passed!{NC}")
        print("=" * 60)
        print()
        print("Test Summary:")
        print(f"  Deployment: {GREEN}✓{NC} Successful")
        print(f"  Secure Boot: {secure_boot_status_msg}")
        print()
        print("SSH to deployed server:")
        print()
        print("Remove old host key (if you get host key verification failed):")
        print(f"  ssh-keygen -R '[localhost]:22220'")
        print()
        print("SSH with normal key checking:")
        print(f"  ssh -p 22220 root@localhost")
        print()
        print("SSH ignoring host key verification:")
        print(f"  ssh -p 22220 -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null root@localhost")
        print()

    return 0

if __name__ == "__main__":
    try:
        sys.exit(main())
    except KeyboardInterrupt:
        print()
        print_warning("Test interrupted by user")
        sys.exit(130)
    except Exception as e:
        print_error(f"Unexpected error: {e}")
        import traceback
        traceback.print_exc()
        sys.exit(1)
