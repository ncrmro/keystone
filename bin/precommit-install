#!/usr/bin/env bash

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null)"

if [ -z "$REPO_ROOT" ]; then
    echo "Error: Not in a git repository"
    exit 1
fi

HOOK_FILE="$REPO_ROOT/.git/hooks/pre-commit"

echo "Setting up pre-commit hook for repo-wide nixfmt formatting and ShellCheck..."

cat > "$HOOK_FILE" << 'EOF'
#!/usr/bin/env bash

set -euo pipefail

echo "Running repo-wide nixfmt on tracked Nix files and ShellCheck on tracked shell scripts..."

if ! command -v nixfmt &> /dev/null; then
    echo "Error: nixfmt is not installed"
    echo "Install it with: nix-env -iA nixpkgs.nixfmt"
    exit 1
fi

if ! command -v shellcheck &> /dev/null; then
    echo "Error: shellcheck is not installed"
    echo "Install it with: nix-env -iA nixpkgs.shellcheck"
    exit 1
fi

TRACKED_NIX_FILES=$(git ls-files '*.nix')
TRACKED_SHELL_FILES=$(git ls-files '*.sh')

if [ -z "$TRACKED_NIX_FILES" ]; then
    echo "No tracked .nix files to format"
else
    echo "Formatting tracked .nix files:"
    echo "$TRACKED_NIX_FILES"

    while IFS= read -r file; do
        if [ -n "$file" ] && [ -f "$file" ]; then
            nixfmt "$file"
        fi
    done <<< "$TRACKED_NIX_FILES"

    echo "nixfmt formatting complete, restaging tracked .nix files"
    git ls-files -z '*.nix' | xargs -0 git add --
fi

if [ -z "$TRACKED_SHELL_FILES" ]; then
    echo "No tracked .sh files to check"
else
    echo "Running ShellCheck on tracked .sh files:"
    echo "$TRACKED_SHELL_FILES"

    while IFS= read -r file; do
        if [ -n "$file" ] && [ -f "$file" ]; then
            shellcheck "$file"
        fi
    done <<< "$TRACKED_SHELL_FILES"

    echo "ShellCheck complete"
fi
EOF

chmod +x "$HOOK_FILE"

echo "Pre-commit hook installed successfully at $HOOK_FILE"
echo "The hook will format tracked .nix files with nixfmt and lint tracked .sh files with ShellCheck"
