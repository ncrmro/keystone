{
  "templating": {
    "list": [
      {
        "allValue": ".+",
        "current": { "selected": true, "text": "All", "value": ".+" },
        "datasource": { "type": "loki", "uid": "loki" },
        "definition": "label_values(agent)",
        "hide": 0,
        "includeAll": true,
        "label": "Agent",
        "multi": true,
        "name": "agent",
        "options": [],
        "query": "label_values(agent)",
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "panels": [
    {
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(count_over_time({agent=~\"$agent\"} |= \"Finished successfully\" [1h]))",
          "refId": "A"
        }
      ],
      "title": "Completed Tasks (1h)",
      "type": "stat"
    },
    {
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(count_over_time({agent=~\"$agent\"} |~ \"(?i)block\" [1h]))",
          "refId": "A"
        }
      ],
      "title": "Blocked Tasks (1h)",
      "type": "stat"
    },
    {
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(count_over_time({agent=~\"$agent\"} |~ \"(?i)error|fail|exception\" [1h]))",
          "refId": "A"
        }
      ],
      "title": "Errors & Failures (1h)",
      "type": "stat"
    },
    {
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 6 },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{agent=~\"$agent\"} |~ \"(?i)error|fail|exception\"",
          "refId": "A"
        }
      ],
      "title": "Errors & Issues Logs",
      "type": "logs"
    },
    {
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 6 },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{agent=~\"$agent\"} |~ \"(?i)block\"",
          "refId": "A"
        }
      ],
      "title": "Blocked Tasks Logs",
      "type": "logs"
    },
    {
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum by(agent) (rate({agent=~\"$agent\"} |= \"Finished successfully\" [$__rate_interval]))",
          "refId": "A"
        }
      ],
      "title": "Task Completion Rate",
      "type": "timeseries"
    }
  ],
  "refresh": "1m",
  "tags": ["keystone", "agents"],
  "timezone": "browser",
  "title": "Keystone OS Agents"
}
