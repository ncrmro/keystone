#!/usr/bin/quickemu --vm
guest_os="linux"
iso="keystone-installer.iso"
disk_img="server/disk.qcow2"
disk_size="20G"
ram="4G"
cpu_cores="2"
display="none"
serial="socket"
ssh_port="22220"

# Secure Boot Configuration
# Enable Secure Boot support in OVMF firmware (UEFI Secure Boot capable)
# This loads OVMF with Secure Boot variables available for key enrollment
# Note: Secure Boot starts DISABLED (Setup Mode) to allow key enrollment
# The test-deployment script will automatically enroll custom keys via lanzaboote
secureboot="on"

# Requirements for Secure Boot automation:
# - UEFI boot mode (enabled by default for Linux guests in quickemu)
# - secureboot="on" option (see above) loads Secure Boot capable OVMF firmware
# - Writable OVMF_VARS.fd for persistent key storage (created in server/ directory)
# - NixOS configuration with lanzaboote module enabled (see vms/test-server/configuration.nix)
