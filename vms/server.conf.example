#!/usr/bin/quickemu --vm
guest_os="linux"
iso="keystone-installer.iso"
disk_img="server/disk.qcow2"
disk_size="20G"
ram="4G"
cpu_cores="2"
display="none"
serial="socket"
ssh_port="22220"

# Secure Boot Configuration
# quickemu automatically enables UEFI boot for Linux guests
# For Secure Boot testing, ensure your quickemu installation uses OVMF with Secure Boot support
# OVMF (Open Virtual Machine Firmware) provides UEFI implementation for QEMU/KVM
# The OVMF_VARS.fd file in server/ directory stores Secure Boot keys and NVRAM state
#
# Requirements for Secure Boot automation:
# - UEFI boot mode (enabled by default for Linux guests in quickemu)
# - OVMF firmware with secureBoot=true support
# - Writable OVMF_VARS.fd for persistent key storage
# - NixOS configuration with lanzaboote module enabled (see examples/test-server.nix)
