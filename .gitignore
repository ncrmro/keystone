# Nix build outputs
result
result-*
installer-iso

# Nix development
.direnv/
.env

# ISO files (they are large)
*.iso

# E2E test artifacts
.test-e2e-screenshots/

# Editor / AI tool files
.vscode/
.gemini/
.opencode/
.ruby-lsp/
.claude/settings.local.json
.claude/settings.json.backup
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Temporary files
tmp/
temp/
.cache/
.jekyll-cache/
.nix-store/
.nixos-test-history

# VM artifacts
vms/*/disk.qcow2
vms/*/OVMF_VARS.fd
vms/*/*.pid
vms/*/*.ports
vms/*/*.log
vms/*/*.socket

# build-vm artifacts (nixos-rebuild build-vm)
.build-vm/
build-vm-*.pid
keystone-buildvm-*.qcow2
build-vm-*.qcow2

# VM configuration (keep .example files tracked)
vms/*.conf

# VM test artifacts (generated by test-deployment script)
vms/test-server/ssh-keys/
vms/test-server/extra-files/

.worktrees
worktree
.claude/worktrees/
__pycache__/

# Node.js (for keystone-installer-ui)
node_modules/
dist/
*.log

# Rust artifacts
target/

# VM screenshots for debugging
screenshots/
# LFS-tracked e2e baseline screenshots (negates the rule above)
!templates/default/tests/e2e/screenshots/
*.sock

# DeepWork runtime artifacts (job definitions are tracked, outputs are not)
.deepwork/sessions/
.deepwork/tmp/
.deepwork/jobs/**/plan.md
.deepwork/jobs/**/implementation_summary.md
.deepwork/jobs/**/review_report.md
.deepwork/jobs/**/build_result.md
.deepwork/jobs/**/merge_result.md
.deepwork/jobs/**/deploy_result.md
.deepwork/jobs/**/validation_report.md
.deepwork/jobs/**/fleet_survey.md

# TUI screenshots (removed from history)
assets/tui/

# Home Manager activation artifacts (generated at activation time)
.hm-activation-detach
