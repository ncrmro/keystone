# =====================================================================
# Nix: Format and Flake Check
# Runs nixfmt check and nix flake check when Nix files change.
# Mirrors the CI pipeline in .github/workflows/test.yml (flake-check).
# =====================================================================
nix_validate:
  description: "Run nixfmt check and nix flake check when Nix files change."
  match:
    include:
      - "**/*.nix"
      - "flake.lock"
    exclude:
      - "tests/**"
  review:
    strategy: matches_together
    instructions: |
      Nix files changed. Run these checks from the project root and report failures:

      1. **Formatting** — Run `nix fmt -- --check **/*.nix` and report any
         unformatted files. Do NOT auto-fix; just list which files need formatting.

      2. **Flake check** — Run `nix flake check` and report any evaluation
         errors, broken module imports, or type mismatches.

      If both pass, report "All checks passed." with a brief summary.

# =====================================================================
# Docs Sync: CLAUDE.md and docs/ stay current with module changes
# When NixOS modules or flake.nix change, verify documentation matches.
# =====================================================================
update_keystone_docs:
  description: "Ensure AGENTS.md and docs/ stay current when NixOS modules, flake outputs, or options change."
  match:
    include:
      - "modules/**/*.nix"
      - "flake.nix"
      - "AGENTS.md"
      - "docs/**"
      - "templates/**"
    exclude:
      - "modules/**/scripts/**"
      - "tests/**"
  review:
    strategy: matches_together
    instructions: |
      When NixOS module files or flake.nix change, check whether AGENTS.md and docs/ need updating.
      Read AGENTS.md and the relevant docs/*.md files, then compare against the changed source files.
      Note: CLAUDE.md is a symlink to AGENTS.md — they are the same file.

      **AGENTS.md checks:**
      - Module File Tree: Does the directory tree listing match the actual filesystem layout?
      - Module descriptions: Do inline descriptions match what the modules actually do?
      - Server Services table: Does it list all services in modules/server/services/?
      - nixosModules/homeModules exports: Do they match flake.nix?
      - Key Options: Does the options list match actual module options?
      - Deployment Patterns: Do example config snippets use correct option names/structure?
      - Domain Architecture: Does the server domain docs match actual domain/port defaults?
      - Packages table: Does it list all packages in packages/?

      **docs/ checks:**
      - docs/index.md: Does the overview match current module structure and features?
      - docs/installation.md: Do installation steps reference correct module names and options?
      - docs/users.md: Does it match keystone.os.users options?
      - docs/terminal.md: Does it match keystone.terminal options?
      - docs/hardware-keys.md: Does it match keystone.os.hardwareKey options?
      - docs/testing-vm.md: Does it match current VM testing workflow?
      - docs/examples.md: Do code examples use correct option paths?

      For any doc that references module options, NixOS config snippets, or CLI commands,
      verify they still match the actual implementation. Flag outdated sections.

      If a module change adds new user-facing features or options that are not yet
      documented in any docs/ file, flag this as "missing documentation".
    additional_context:
      unchanged_matching_files: true

# =====================================================================
# Specs Sync: Requirements specs stay current with implementation
# When modules, packages, or CLI scripts change, verify the relevant
# specs in specs/ still accurately describe the implementation.
# =====================================================================
specs_sync:
  description: "Ensure specs/ requirements stay in sync with implementation when code changes."
  match:
    include:
      - "modules/**/*.nix"
      - "packages/**/*.sh"
      - "packages/**/*.nix"
      - "flake.nix"
      - "specs/**"
      - ".deepwork/jobs/**"
    exclude:
      - "tests/**"
      - "modules/**/scripts/**"
  review:
    strategy: matches_together
    instructions: |
      When implementation files change, check whether the corresponding specs
      in specs/ still accurately describe the behavior.

      For each spec (REQ-XXX):
      1. Read the requirements.md file
      2. Identify which source files implement those requirements (listed in
         "Affected Modules" section)
      3. Compare the spec's requirements against the actual implementation
      4. Flag any mismatches:
         - Requirements that describe behavior the code doesn't implement
         - Code behavior not covered by any requirement
         - Outdated file paths, option names, or CLI flags in the spec

      When spec files change without corresponding code changes, verify the
      spec still matches what the code actually does.

      Check the "Affected Modules" section lists all relevant files.
    additional_context:
      unchanged_matching_files: true

# =====================================================================
# Tests Sync: Evaluation tests stay current with module changes
# When modules or flake.nix change, verify tests/ still cover the
# changed modules and that existing tests pass.
# =====================================================================
tests_sync:
  description: "Ensure tests/ evaluation tests stay current when modules change."
  match:
    include:
      - "modules/**/*.nix"
      - "flake.nix"
      - "tests/**"
    exclude:
      - "modules/**/scripts/**"
  review:
    strategy: matches_together
    instructions: |
      When module files change, check whether the test suite covers the changes.

      1. Run `nix flake check --no-build` to verify all evaluation tests pass.
      2. For each changed module, check if the relevant test file in tests/module/
         exercises the new or changed options:
         - modules/os/** → tests/module/os-evaluation.nix
         - modules/os/agents/** → tests/module/agent-evaluation.nix
         - modules/server/** → tests/module/server-evaluation.nix
         - modules/terminal/** → covered via agent-evaluation.nix (agents import terminal)
         - templates/ → tests/module/template-evaluation.nix
      3. If a new user-facing option is added but not exercised in any test, flag
         it as "missing test coverage".
      4. If test files change, verify they still evaluate cleanly.

      Report which tests cover which changes, and flag any gaps.

# =====================================================================
# Requirements Traceability
# Every Nix module header comment should link to its relevant
# conventions (conventions/*.md) and spec requirements (specs/REQ-*).
# Enables: `rg "tool.cli-coding-agents"` or `rg "REQ-007"` to find related modules.
# =====================================================================
requirements_traceability:
  description: "Verify Nix module headers link to relevant conventions and spec requirements."
  match:
    include:
      - "modules/**/*.nix"
    exclude:
      - "modules/**/scripts/**"
      - "tests/**"
  review:
    strategy: per_file
    instructions: |
      Each Nix module file MUST have a header comment block that includes:

      1. **Convention references** — If the module implements behavior documented
         in a conventions/ file, the header MUST contain a comment linking to it.
         Format: `# See conventions/<name>.md` (one per line).
         Example: `# See conventions/tool.cli-coding-agents.md`

      2. **Spec references** — If the module implements requirements from a spec,
         the header MUST reference the spec ID.
         Format: `# Implements REQ-XXX` or `# See specs/REQ-XXX-<name>.md`
         Example: `# Implements REQ-007 (OS Agents)`

      These MUST be links/references only — do NOT inline convention content
      into the comment. The goal is grep-ability: `rg "conventions/tool.cli"` or
      `rg "REQ-007"` should find every module that touches that concern.

      **How to check:**
      - Read the module's header comment (first comment block before the opening `{`)
      - Read the module body to understand what it does
      - Check conventions/ for any convention that covers this module's domain
      - Check specs/ for any REQ that lists this file in its "Affected Modules"
      - Flag missing references as "missing convention link" or "missing spec reference"

      **Exceptions** (do not flag):
      - Trivial modules that only re-export or barrel-import other modules
      - Module files under 20 lines
      - Files that genuinely have no matching convention or spec
