#!/usr/bin/env bash
# pdf-extract — Convert PDF to markdown with element-level bounding box citations.
#
# Uses Docling (IBM) for structured document conversion. Docling preserves
# headings, tables, lists and produces element-level bounding box metadata.
# Outputs {name}.md and {name}.bbox.json.
#
# Implements REQ-024.1–REQ-024.5
#
# Usage: pdf-extract <input.pdf> [--output-dir <dir>] [--ocr-mode auto|force|off]
set -euo pipefail

usage() {
  echo "Usage: pdf-extract <input.pdf> [--output-dir <dir>] [--ocr-mode auto|force|off]"
  echo ""
  echo "Convert a PDF to markdown with element-level bounding box metadata."
  echo ""
  echo "Options:"
  echo "  --output-dir <dir>       Output directory (default: same as input file)"
  echo "  --ocr-mode auto|force|off  OCR strategy (default: auto)"
  echo "  --help                   Show this help"
  exit "${1:-0}"
}

INPUT=""
OUTPUT_DIR=""
OCR_MODE="auto"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --output-dir) OUTPUT_DIR="$2"; shift 2 ;;
    --ocr-mode) OCR_MODE="$2"; shift 2 ;;
    --help) usage 0 ;;
    -*) echo "Unknown option: $1" >&2; usage 1 ;;
    *) INPUT="$1"; shift ;;
  esac
done

if [[ -z "$INPUT" ]]; then
  echo "Error: no input PDF specified" >&2
  usage 1
fi

if [[ ! -f "$INPUT" ]]; then
  echo "Error: file not found: $INPUT" >&2
  exit 1
fi

case "$OCR_MODE" in
  auto|force|off) ;;
  *) echo "Error: invalid ocr-mode: $OCR_MODE (choose: auto, force, off)" >&2; exit 1 ;;
esac

BASENAME=$(basename "$INPUT" .pdf)
INPUT_DIR=$(dirname "$INPUT")
OUTPUT_DIR="${OUTPUT_DIR:-$INPUT_DIR}"
mkdir -p "$OUTPUT_DIR"

TMPDIR_WORK=$(mktemp -d)
trap 'rm -rf "$TMPDIR_WORK"' EXIT

# ── Build docling CLI arguments ──────────────────────────────────────
DOCLING_ARGS=(
  convert
  --from pdf
  --to md
  --output "$TMPDIR_WORK"
)

# OCR strategy: auto lets docling detect scanned pages, force always OCRs,
# off skips OCR entirely (REQ-024.5)
case "$OCR_MODE" in
  auto)  DOCLING_ARGS+=(--ocr-engine easyocr) ;;
  force) DOCLING_ARGS+=(--ocr-engine easyocr --force-ocr) ;;
  off)   DOCLING_ARGS+=(--no-ocr) ;;
esac

DOCLING_ARGS+=("$INPUT")

echo "pdf-extract: running docling on $INPUT (ocr=$OCR_MODE)" >&2

# ── Run docling ──────────────────────────────────────────────────────
docling "${DOCLING_ARGS[@]}" 2>&1 | while IFS= read -r line; do
  echo "  docling: $line" >&2
done

# ── Collect outputs ──────────────────────────────────────────────────
# Docling writes {basename}.md in the output dir
MD_SRC=$(find "$TMPDIR_WORK" -name "*.md" -type f | head -1)

if [[ -z "$MD_SRC" ]] || [[ ! -f "$MD_SRC" ]]; then
  echo "Error: docling produced no markdown output" >&2
  exit 1
fi

MD_OUT="$OUTPUT_DIR/$BASENAME.md"
cp "$MD_SRC" "$MD_OUT"

# ── Generate bbox metadata from docling JSON export ──────────────────
# Re-run docling with JSON output to get element-level bounding boxes
DOCLING_JSON_ARGS=(
  convert
  --from pdf
  --to json
  --output "$TMPDIR_WORK/json"
)

case "$OCR_MODE" in
  auto)  DOCLING_JSON_ARGS+=(--ocr-engine easyocr) ;;
  force) DOCLING_JSON_ARGS+=(--ocr-engine easyocr --force-ocr) ;;
  off)   DOCLING_JSON_ARGS+=(--no-ocr) ;;
esac

DOCLING_JSON_ARGS+=("$INPUT")

mkdir -p "$TMPDIR_WORK/json"
docling "${DOCLING_JSON_ARGS[@]}" >/dev/null 2>&1 || true

JSON_SRC=$(find "$TMPDIR_WORK/json" -name "*.json" -type f | head -1)
BBOX_OUT="$OUTPUT_DIR/$BASENAME.bbox.json"

if [[ -n "$JSON_SRC" ]] && [[ -f "$JSON_SRC" ]]; then
  # Extract element-level bounding boxes from docling's JSON output.
  # Each element has page_no, bbox (x0, y0, x1, y1), and label (heading, paragraph, table, etc.)
  jq '[
    .main_text[]? // .body[]? |
    select(.prov != null) |
    .prov[] |
    {
      page: .page_no,
      label: .type,
      bbox: {
        xMin: .bbox.l,
        yMin: .bbox.t,
        xMax: .bbox.r,
        yMax: .bbox.b
      }
    }
  ] // []' "$JSON_SRC" > "$BBOX_OUT" 2>/dev/null || echo '[]' > "$BBOX_OUT"
else
  echo "pdf-extract: warning: could not generate bbox metadata" >&2
  echo '[]' > "$BBOX_OUT"
fi

echo "pdf-extract: wrote markdown to $MD_OUT" >&2
echo "pdf-extract: wrote bbox metadata to $BBOX_OUT" >&2
