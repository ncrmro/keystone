#!/usr/bin/env bash
# immich-search — CLI for querying the Immich REST API.
#
# Subcommands: smart, person, recent
# Auth via IMMICH_API_KEY env var or --api-key-file flag.
# IMMICH_URL env var for server address.
#
# Implements REQ-024.19–REQ-024.22
#
# Usage: immich-search <subcommand> [options]
set -euo pipefail

usage() {
  echo "Usage: immich-search <command> [options]"
  echo ""
  echo "Query the Immich API for photos, screenshots, and videos."
  echo ""
  echo "Commands:"
  echo "  smart <query>          Search by text (CLIP/OCR)"
  echo "  person <name>          Search by person/face name"
  echo "  recent [--days N]      List recent assets (default: 7 days)"
  echo ""
  echo "Global options:"
  echo "  --api-key-file <path>  Read API key from file (default: \$IMMICH_API_KEY)"
  echo "  --url <url>            Immich server URL (default: \$IMMICH_URL)"
  echo "  --type <type>          Filter by asset type: IMAGE, VIDEO, ALL (default: ALL)"
  echo "  --limit <n>            Max results (default: 50)"
  echo "  --help                 Show this help"
  exit "${1:-0}"
}

# ── Parse global options ─────────────────────────────────────────────
API_KEY="${IMMICH_API_KEY:-}"
IMMICH_URL="${IMMICH_URL:-}"
ASSET_TYPE="ALL"
LIMIT=50
COMMAND=""
QUERY=""
DAYS=7

# First pass: extract global options and command
ARGS=()
while [[ $# -gt 0 ]]; do
  case "$1" in
    --api-key-file)
      if [[ ! -f "$2" ]]; then
        echo "Error: API key file not found: $2" >&2
        exit 1
      fi
      API_KEY=$(cat "$2" | tr -d '[:space:]')
      shift 2
      ;;
    --url) IMMICH_URL="$2"; shift 2 ;;
    --type) ASSET_TYPE="$2"; shift 2 ;;
    --limit) LIMIT="$2"; shift 2 ;;
    --days) DAYS="$2"; shift 2 ;;
    --help) usage 0 ;;
    -*) echo "Unknown option: $1" >&2; usage 1 ;;
    *)
      if [[ -z "$COMMAND" ]]; then
        COMMAND="$1"
      else
        ARGS+=("$1")
      fi
      shift
      ;;
  esac
done

if [[ -z "$COMMAND" ]]; then
  echo "Error: no command specified" >&2
  usage 1
fi

if [[ -z "$API_KEY" ]]; then
  echo "Error: no API key. Set IMMICH_API_KEY or use --api-key-file" >&2
  exit 1
fi

if [[ -z "$IMMICH_URL" ]]; then
  echo "Error: no server URL. Set IMMICH_URL or use --url" >&2
  exit 1
fi

# Strip trailing slash
IMMICH_URL="${IMMICH_URL%/}"

# ── Helper: format asset list to structured JSON ─────────────────────
format_assets() {
  jq '[.[] | {
    id: .id,
    filename: (.originalFileName // .originalPath // "unknown"),
    date: .fileCreatedAt,
    type: .type,
    thumbnailUrl: "'"$IMMICH_URL"'/api/assets/\(.id)/thumbnail",
    isFavorite: .isFavorite
  }]'
}

# ── API helper ───────────────────────────────────────────────────────
api_post() {
  local endpoint="$1"
  local body="$2"
  curl -sf \
    -H "x-api-key: $API_KEY" \
    -H "Content-Type: application/json" \
    -d "$body" \
    "$IMMICH_URL/api$endpoint"
}

api_get() {
  local endpoint="$1"
  curl -sf \
    -H "x-api-key: $API_KEY" \
    "$IMMICH_URL/api$endpoint"
}

# ── Commands ─────────────────────────────────────────────────────────
case "$COMMAND" in
  smart)
    QUERY="${ARGS[0]:-}"
    if [[ -z "$QUERY" ]]; then
      echo "Error: smart search requires a query string" >&2
      echo "Usage: immich-search smart <query>" >&2
      exit 1
    fi

    BODY=$(jq -n \
      --arg query "$QUERY" \
      --argjson size "$LIMIT" \
      --arg type "$ASSET_TYPE" \
      'if $type == "ALL" then {query: $query, size: $size}
       else {query: $query, size: $size, type: $type} end')

    RESULT=$(api_post "/search/smart" "$BODY")
    echo "$RESULT" | jq '.assets.items // []' | format_assets
    ;;

  person)
    PERSON_NAME="${ARGS[0]:-}"
    if [[ -z "$PERSON_NAME" ]]; then
      echo "Error: person search requires a name" >&2
      echo "Usage: immich-search person <name>" >&2
      exit 1
    fi

    # List all people, find matching name
    PEOPLE=$(api_get "/people")
    PERSON_ID=$(echo "$PEOPLE" | jq -r \
      --arg name "$PERSON_NAME" \
      '.people[] | select(.name | ascii_downcase | contains($name | ascii_downcase)) | .id' \
      | head -1)

    if [[ -z "$PERSON_ID" ]]; then
      echo "[]"
      exit 0
    fi

    # Get assets for this person
    RESULT=$(api_get "/people/$PERSON_ID/assets")
    echo "$RESULT" | jq ".[:$LIMIT]" | format_assets
    ;;

  recent)
    # Calculate date range
    SINCE=$(date -d "$DAYS days ago" -u +"%Y-%m-%dT00:00:00.000Z" 2>/dev/null \
      || date -v-"${DAYS}d" -u +"%Y-%m-%dT00:00:00.000Z" 2>/dev/null)

    BODY=$(jq -n \
      --arg since "$SINCE" \
      --argjson size "$LIMIT" \
      --arg type "$ASSET_TYPE" \
      'if $type == "ALL" then
        {takenAfter: $since, size: $size, order: "desc"}
       else
        {takenAfter: $since, size: $size, order: "desc", type: $type}
       end')

    RESULT=$(api_post "/search/metadata" "$BODY")
    echo "$RESULT" | jq '.assets.items // []' | format_assets
    ;;

  *)
    echo "Unknown command: $COMMAND" >&2
    usage 1
    ;;
esac
